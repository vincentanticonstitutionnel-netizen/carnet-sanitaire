document.getElementById('add-medicament-empty').addEventListener('click', () => openMedModal(null));
document.getElementById('med-close').addEventListener('click', closeMedModal);
document.getElementById('med-cancel').addEventListener('click', closeMedModal);
document.getElementById('med-save').addEventListener('click', saveMedicament);
document.getElementById('med-delete').addEventListener('click', deleteMedicament);
