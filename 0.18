  btn.addEventListener('click', () => {
    state.filtres[k] = !state.filtres[k];
    btn.setAttribute('aria-pressed', state.filtres[k]);
    // Femelles/mâles s'excluent
    if (k === 'femelles' && state.filtres.femelles) {
      state.filtres.males = false;
      document.getElementById('filter-males').setAttribute('aria-pressed', false);
    }
    if (k === 'males' && state.filtres.males) {
      state.filtres.femelles = false;
      document.getElementById('filter-femelles').setAttribute('aria-pressed', false);
    }
    render();
  });
});

