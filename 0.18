// Réglages de l'exploitation
document.getElementById('open-settings').addEventListener('click', openSettingsModal);
document.getElementById('settings-close').addEventListener('click', closeSettingsModal);
document.getElementById('settings-save').addEventListener('click', saveSettings);
document.getElementById('settings-modal-bg').addEventListener('click', (e) => {
  if (e.target.id === 'settings-modal-bg') closeSettingsModal();
});

document.getElementById('modal-bg').addEventListener('click', (e) => {
  if (e.target.id === 'modal-bg') closeModal();
});
// Fermeture de la modale "backups" : si on est en mode réconciliation
// (post-connexion sans choix), une fermeture sans choix annule la connexion.
function closeBackupsModal() {
  if (cloudState.reconciling) {
    // Comportement = annuler la connexion (l'utilisateur n'a pas choisi)
    document.getElementById('backups-modal-bg').classList.remove('show');
    if (getProvider()) getProvider().disconnect();
    cloudState.provider = null;
    cloudState.status = 'disconnected';
    cloudState.lastSync = null;
    cloudState.dirty = false;
    cloudState.reconciling = false;
    saveCloudConfig();
    renderCloudBar();
    toast('Connexion annulée — aucune donnée modifiée');
  } else {
    document.getElementById('backups-modal-bg').classList.remove('show');
  }
}

document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    closeModal();
    document.getElementById('config-modal-bg').classList.remove('show');
    closeAddModal();
    closeMedModal();
    closeSettingsModal();
    closeOrdModal();
    closePhotoZoom();
    if (document.getElementById('backups-modal-bg').classList.contains('show')) {
      closeBackupsModal();
    }
  }
});

// Modales cloud (le bouton cloud-config est rebindé dynamiquement par renderCloudBar)
document.getElementById('config-close').addEventListener('click', () => {
  document.getElementById('config-modal-bg').classList.remove('show');
});
document.getElementById('config-modal-bg').addEventListener('click', (e) => {
  if (e.target.id === 'config-modal-bg') {
    document.getElementById('config-modal-bg').classList.remove('show');
  }
});
document.getElementById('backups-close').addEventListener('click', closeBackupsModal);
document.getElementById('backups-modal-bg').addEventListener('click', (e) => {
  if (e.target.id === 'backups-modal-bg') {
    closeBackupsModal();
  }
});

/* ============================================================
   INIT
   ============================================================ */

load();
loadCloudConfig();
render();
renderCloudBar();

// Reconnexion au démarrage si on était précédemment connecté.
//
// Stratégie : on s'appuie UNIQUEMENT sur le token persisté en localStorage.
// La requête OAuth silencieuse via Google Identity Services (prompt: 'none') est
// systématiquement bloquée par la politique Cross-Origin-Opener-Policy de
// GitHub Pages — elle a été désactivée car contre-productive.
//
//   • Token cache valide (< 1h) → connexion immédiate sans aucun appel réseau
//   • Token absent ou expiré → état "needs_reconnect" avec bouton visible
//
// Conséquence pratique : popup OAuth nécessaire au maximum 1× par heure.
// Tant que le token est en cache, F5 / fermer-rouvrir onglet / fermer-rouvrir
// navigateur sont totalement transparents.
function reconnectFromCache() {
  const provider = getProvider();
  if (!provider) return;

  if (provider._loadPersistedToken && provider._loadPersistedToken()) {
    cloudState.status = 'connected';
    renderCloudBar();
    // Au démarrage, on lance une sync automatique en arrière-plan pour récupérer
    // les éventuelles modifs faites sur d'autres appareils.
    setTimeout(() => maybeMigrateAndSync(), 500);
    return;
  }
  // Pas de token valide en cache : on attend une action utilisateur explicite
  cloudState.status = 'needs_reconnect';
  cloudState.errorMessage = 'Session expirée — clique pour reconnecter';
  renderCloudBar();
}

// Détection du format Drive : si pas de manifest, mais des anciennes sauvegardes
// monolithiques, on propose la migration. Sinon, sync normale.
async function maybeMigrateAndSync() {
  const provider = getProvider();
  if (!provider) return;

  try {
    // Vérifier si le manifest existe
    const manifestRaw = await provider.loadFile('manifest.json');
    if (manifestRaw) {
      // Format v0.18 déjà en place → sync normale
      await synchronize('auto');
      return;
    }

    // Pas de manifest : chercher des sauvegardes monolithiques
    const files = await provider.list();
    const oldFiles = files.filter(f => /^carnet-\d{4}-\d{2}/.test(f.name));
    if (oldFiles.length === 0) {
      // Drive vide : première utilisation → sync (qui créera tout)
      await synchronize('auto');
      return;
    }

    // Anciennes sauvegardes détectées → proposer la migration
    proposeMigration(oldFiles);
  } catch (e) {
    if (e.code === 'NEED_RECONNECT') {
      handleCloudError(e, '');
      return;
    }
    console.warn('Échec de la détection de migration:', e);
    // En cas d'erreur, on tente quand même une sync normale
    await synchronize('auto').catch(() => {});
  }
}

// Affiche une modal proposant la migration de l'ancien format vers v0.18
function proposeMigration(oldFiles) {
  const recent = [...oldFiles].sort((a, b) =>
    (b.modifiedTime || '').localeCompare(a.modifiedTime || '')
  )[0];
  const fileSize = recent.size > 1024 * 1024
    ? Math.round(recent.size / 1024 / 1024 * 10) / 10 + ' Mo'
    : Math.round(recent.size / 1024) + ' Ko';

  const msg = `Le système de sauvegarde est passé en version 5.0 (multi-fichiers).\n\n` +
    `Il y a ${oldFiles.length} ancienne${oldFiles.length > 1 ? 's' : ''} sauvegarde${oldFiles.length > 1 ? 's' : ''} sur ton Drive (la plus récente : ${recent.name}, ${fileSize}).\n\n` +
    `Veux-tu migrer maintenant ? La migration :\n` +
    `  • Récupère tes données depuis ${recent.name}\n` +
    `  • Crée les fichiers du nouveau format (cheptel.json, ordonnances.json, photos/)\n` +
    `  • Supprime les anciennes sauvegardes monolithiques\n\n` +
    `Tu peux refuser et le faire plus tard via le bouton Synchroniser.`;

  if (confirm(msg)) {
    runMigration(oldFiles, recent).catch(e => {
      console.error('Migration échouée:', e);
      toast('Migration échouée : ' + e.message, 'error');
    });
  }
}

// Effectue la migration de l'ancien format monolithique vers le nouveau
async function runMigration(oldFiles, recentFile) {
  const provider = getProvider();
  cloudState.status = 'syncing';
  renderCloudBar();
  toast('Migration en cours…');

  try {
    // 1. Charger l'ancienne sauvegarde la plus récente
    const oldRaw = await provider.load(recentFile.id);
    const oldData = JSON.parse(oldRaw);

    // 2. Importer dans le state local SI le local est vide ou plus ancien
    // Heuristique simple : si on n'a pas plus d'animaux localement, on prend le distant
    if ((state.animaux || []).length === 0 ||
        (oldData.animaux && oldData.animaux.length > state.animaux.length)) {
      state.animaux = oldData.animaux || [];
      state.medicaments = oldData.medicaments || [];
      state.ordonnances = oldData.ordonnances || [];
      state.soins = oldData.soins || [];
      if (oldData.settings) state.settings = { ...state.settings, ...oldData.settings };
    }

    // 3. Initialiser les versions (toutes à 1 pour forcer un upload)
    state.versions = {
      cheptel: 1,
      medicaments: 1,
      ordonnances: 1,
      soins: 1,
      settings: 1
    };

    // 4. Synchroniser : ça va uploader tous les fichiers + photos
    persist();
    render();
    await synchronize('manual');

    // 5. Supprimer les anciennes sauvegardes monolithiques après succès
    let deleted = 0;
    for (const f of oldFiles) {
      try {
        await provider.delete(f.id);
        deleted++;
      } catch (e) {
        console.warn(`Suppression ancienne sauvegarde ${f.name} échouée:`, e);
      }
    }

    toast(`Migration terminée — ${deleted} ancienne${deleted > 1 ? 's' : ''} sauvegarde${deleted > 1 ? 's' : ''} supprimée${deleted > 1 ? 's' : ''}`, 'success');
  } catch (e) {
    handleCloudError(e, 'Migration échouée');
  }
}

reconnectFromCache();

// Rafraîchit l'horodatage relatif toutes les 60s
setInterval(() => {
  if (cloudState.status === 'connected') renderCloudBar();
}, 60000);
</script>
</body>
</html>
