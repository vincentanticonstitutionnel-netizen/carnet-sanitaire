/* ============================================================
   AJOUT MANUEL D'ANIMAL
   ============================================================ */

// Remplit les listes déroulantes de race avec un tri intelligent :
// - "Suggérées" : races déjà présentes dans le cheptel + Croisée (39)
// - "Toutes les races" : toutes les autres, groupées par type
function populateAddFormSelects() {
  const raceSelect = document.getElementById('add-race');
  const mereRaceSelect = document.getElementById('add-mere-race');
  const pereRaceSelect = document.getElementById('add-pere-race');

  // 1. Codes race présents dans le cheptel (animaux + parents IPG/CPB/père)
  const cheptelCodes = new Set();
  for (const a of state.animaux) {
    if (a.codeRace) cheptelCodes.add(a.codeRace);
    if (a.mereIPG?.codeRace) cheptelCodes.add(a.mereIPG.codeRace);
    if (a.mereCPB?.codeRace) cheptelCodes.add(a.mereCPB.codeRace);
    if (a.pere?.codeRace) cheptelCodes.add(a.pere.codeRace);
  }
  // 2. Toujours inclure la croisée dans les suggestions (cas fréquent à saisir)
  cheptelCodes.add('39');
  // Filtrer aux codes effectivement reconnus
  const suggested = Array.from(cheptelCodes).filter(c => RACES[c]);
  // Tri par fréquence dans le cheptel (plus fréquente en premier)
  const counts = {};
  for (const a of state.animaux) {
    if (a.codeRace) counts[a.codeRace] = (counts[a.codeRace] || 0) + 1;
  }
  suggested.sort((a, b) => (counts[b] || 0) - (counts[a] || 0) || RACES[a].nom.localeCompare(RACES[b].nom, 'fr'));

  // 3. Toutes les autres races, groupées par type
  const typesOrder = { 'viande': 1, 'mixte': 2, 'lait': 3, 'croisé': 4, 'croise': 4 };
  const others = Object.keys(RACES).filter(c => !cheptelCodes.has(c));
  const groups = {};
  for (const code of others) {
    const t = RACES[code].type || 'autre';
    (groups[t] = groups[t] || []).push(code);
  }
  for (const t in groups) {
    groups[t].sort((a, b) => RACES[a].nom.localeCompare(RACES[b].nom, 'fr'));
  }

  const labels = { 'viande': 'Type viande', 'mixte': 'Type mixte', 'lait': 'Type lait', 'croisé': 'Croisés', 'croise': 'Croisés' };

  const buildOptions = (firstOption) => {
    let html = `<option value="">${firstOption}</option>`;
    // Section "Suggérées"
    if (suggested.length > 0) {
      html += '<optgroup label="Races du cheptel">';
      for (const code of suggested) {
        const r = RACES[code];
        const star = r.principale ? ' ★' : '';
        const count = counts[code] ? ` · ${counts[code]} animal${counts[code] > 1 ? 'aux' : ''}` : '';
        html += `<option value="${code}">${r.nom}${star} (${code})${count}</option>`;
      }
      html += '</optgroup>';
    }
    // Section "Toutes les autres", par type
    for (const t of ['viande', 'mixte', 'lait', 'croisé', 'croise']) {
      if (!groups[t] || groups[t].length === 0) continue;
      html += `<optgroup label="${labels[t]}">`;
      for (const code of groups[t]) {
        const r = RACES[code];
        const star = r.principale ? ' ★' : '';
        html += `<option value="${code}">${r.nom}${star} (${code})</option>`;
      }
      html += '</optgroup>';
    }
    return html;
  };

  raceSelect.innerHTML = buildOptions('— Choisir —');
  mereRaceSelect.innerHTML = buildOptions('— Inconnue —');
  pereRaceSelect.innerHTML = buildOptions('— Inconnue —');
}

// Remplit la liste déroulante des mères potentielles (femelles présentes)
function populateMereSelect() {
  const sel = document.getElementById('add-mere-select');
  const meres = state.animaux
    .filter(a => a.sexe === 'F' && !a.dateSortie)
    .sort((a, b) => (a.nom || '').localeCompare(b.nom || '', 'fr'));
  let html = '<option value="">— Aucune ou inconnue —</option>';
  for (const m of meres) {
    const label = (m.nom || `[${m.numTravail}]`) + ` · n°${m.numTravail || m.numNational.slice(-4)} · ${m.libelleRace}`;
    html += `<option value="${m.id}">${label}</option>`;
  }
  sel.innerHTML = html;
}

// Remplit la liste déroulante des pères potentiels (mâles présents ≥ 8 mois)
function populatePereSelect() {
  const sel = document.getElementById('add-pere-select');
  if (!sel) return;
  const peres = state.animaux
    .filter(a => {
      if (a.sexe !== 'M' || a.dateSortie) return false;
      const age = calcAge(a.dateNaissance);
      return age && age.totalMonths >= 8;
    })
    .sort((a, b) => (a.nom || '').localeCompare(b.nom || '', 'fr'));
  let html = '<option value="">— Inconnu ou hors cheptel —</option>';
  for (const p of peres) {
    const age = calcAge(p.dateNaissance);
    const ageLabel = age.years > 0 ? `${age.years} an${age.years > 1 ? 's' : ''}` : `${age.totalMonths} mois`;
    const label = (p.nom || `[${p.numTravail}]`) + ` · n°${p.numTravail || p.numNational.slice(-4)} · ${p.libelleRace} · ${ageLabel}`;
    html += `<option value="${p.id}">${label}</option>`;
  }
  sel.innerHTML = html;
}

// Etat de la modal d'ajout
const addFormState = { step: 1, draft: {} };

function openAddModal() {
  // Reset complet
  addFormState.step = 1;
  addFormState.draft = {};
  document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
  document.getElementById('form-step-1').classList.add('active');
  document.getElementById('form-indicator').innerHTML = '<strong>Étape 1/2</strong> · Identification';

  // Reset des champs
  ['add-num-national', 'add-num-travail', 'add-nom', 'add-mere-num',
   'add-mere-nom', 'add-pere-num', 'add-pere-nom'].forEach(id => {
    document.getElementById(id).value = '';
  });
  document.querySelectorAll('input[name="add-sexe"]').forEach(r => r.checked = false);
  document.getElementById('add-naissance').value = '';
  document.getElementById('add-race').value = '';
  document.getElementById('add-mere-race').value = '';
  document.getElementById('add-pere-race').value = '';
  document.getElementById('add-mere-select').value = '';
  document.getElementById('add-pere-select').value = '';
  document.getElementById('add-cause-entree').value = 'N';
  document.getElementById('add-date-entree').value = '';
  document.getElementById('row-date-entree').hidden = true;

  // Reset des erreurs
  document.querySelectorAll('.form-error').forEach(e => e.hidden = true);
  document.querySelectorAll('[aria-invalid="true"]').forEach(e => e.removeAttribute('aria-invalid'));

  populateAddFormSelects();
  populateMereSelect();
  populatePereSelect();
  document.getElementById('add-modal-bg').classList.add('show');
  setTimeout(() => document.getElementById('add-num-national').focus(), 50);
}

function closeAddModal() {
  document.getElementById('add-modal-bg').classList.remove('show');
}

// Validation étape 1 et passage à étape 2
function validateAndNextStep() {
  // Reset erreurs
  document.querySelectorAll('.form-error').forEach(e => e.hidden = true);
  document.querySelectorAll('#form-step-1 [aria-invalid="true"]').forEach(e => e.removeAttribute('aria-invalid'));

  const numNat = document.getElementById('add-num-national').value.trim().replace(/\s+/g, '');
  const sexe = document.querySelector('input[name="add-sexe"]:checked')?.value;
  const naissance = document.getElementById('add-naissance').value;
  const codeRace = document.getElementById('add-race').value;

  let hasError = false;

  // Validation n° national : 8 à 12 chiffres
  if (!numNat) {
    showFieldError('add-num-national', 'err-num-national', 'Le n° national est obligatoire.');
    hasError = true;
  } else if (!/^\d{8,12}$/.test(numNat)) {
    showFieldError('add-num-national', 'err-num-national', 'Le n° doit contenir 8 à 12 chiffres uniquement.');
    hasError = true;
  } else {
    // Vérification d'unicité
    const id = 'FR' + numNat;
    if (state.animaux.some(a => a.id === id || a.numNational === numNat)) {
      showFieldError('add-num-national', 'err-num-national', 'Un animal avec ce n° existe déjà dans ta base.');
      hasError = true;
    }
  }

  if (!sexe) {
    document.getElementById('err-sexe').textContent = 'Sélectionner un sexe.';
    document.getElementById('err-sexe').hidden = false;
    hasError = true;
  }

  if (!naissance) {
    showFieldError('add-naissance', 'err-naissance', 'La date de naissance est obligatoire.');
    hasError = true;
  } else {
    const d = new Date(naissance);
    const now = new Date();
    if (d > now) {
      showFieldError('add-naissance', 'err-naissance', 'La date de naissance ne peut être dans le futur.');
      hasError = true;
    } else if (d.getFullYear() < 1990) {
      showFieldError('add-naissance', 'err-naissance', 'Date de naissance trop ancienne (avant 1990 ?).');
      hasError = true;
    }
  }

  if (!codeRace) {
    showFieldError('add-race', 'err-race', 'Sélectionner une race.');
    hasError = true;
  }

  if (hasError) return;

  // Stocke dans le brouillon
  addFormState.draft = {
    numNational: numNat,
    numTravail: document.getElementById('add-num-travail').value.trim() || numNat.slice(-4),
    nom: document.getElementById('add-nom').value.trim() || null,
    sexe: sexe,
    dateNaissance: naissance,
    codeRace: codeRace,
    causeEntree: document.getElementById('add-cause-entree').value,
    dateEntree: document.getElementById('add-date-entree').value || naissance
  };

  // Passage étape 2
  addFormState.step = 2;
  document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
  document.getElementById('form-step-2').classList.add('active');
  document.getElementById('form-indicator').innerHTML = '<strong>Étape 2/2</strong> · Filiation (optionnelle)';
}

function showFieldError(fieldId, errId, msg) {
  document.getElementById(fieldId).setAttribute('aria-invalid', 'true');
  const err = document.getElementById(errId);
  err.textContent = msg;
  err.hidden = false;
}

function backToStep1() {
  addFormState.step = 1;
  document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
  document.getElementById('form-step-1').classList.add('active');
  document.getElementById('form-indicator').innerHTML = '<strong>Étape 1/2</strong> · Identification';
}

// Construction de l'objet animal final et sauvegarde
function saveNewAnimal() {
  const d = addFormState.draft;
  const codeRace = d.codeRace;

  // Construction mère IPG : priorité à la sélection cheptel, sinon saisie manuelle
  let mereIPG = null;
  const mereSelectedId = document.getElementById('add-mere-select').value;
  if (mereSelectedId) {
    const mere = state.animaux.find(a => a.id === mereSelectedId);
    if (mere) {
      mereIPG = {
        pays: mere.pays,
        numNational: mere.numNational,
        nom: mere.nom,
        codeRace: mere.codeRace,
        libelleRace: mere.libelleRace
      };
    }
  } else {
    const mereNum = document.getElementById('add-mere-num').value.trim();
    const mereNom = document.getElementById('add-mere-nom').value.trim();
    const mereRace = document.getElementById('add-mere-race').value;
    if (mereNum || mereNom) {
      mereIPG = {
        pays: 'FR',
        numNational: mereNum || null,
        nom: mereNom || null,
        codeRace: mereRace || null,
        libelleRace: mereRace ? RACES[mereRace].nom : null
      };
    }
  }

  // Père : priorité à la sélection du cheptel, sinon saisie manuelle
  let pere = null;
  const pereSelectedId = document.getElementById('add-pere-select').value;
  if (pereSelectedId) {
    const p = state.animaux.find(a => a.id === pereSelectedId);
    if (p) {
      pere = {
        pays: p.pays,
        numNational: p.numNational,
        nom: p.nom,
        codeRace: p.codeRace,
        libelleRace: p.libelleRace
      };
    }
  } else {
    const pereNum = document.getElementById('add-pere-num').value.trim();
    const pereNom = document.getElementById('add-pere-nom').value.trim();
    const pereRace = document.getElementById('add-pere-race').value;
    if (pereNum || pereNom) {
      pere = {
        pays: 'FR',
        numNational: pereNum || null,
        nom: pereNom || null,
        codeRace: pereRace || null,
        libelleRace: pereRace ? RACES[pereRace].nom : null
      };
    }
  }

  const animal = {
    id: 'FR' + d.numNational,
    pays: 'FR',
    numNational: d.numNational,
    numTravail: d.numTravail,
    nom: d.nom,
    dateNaissance: d.dateNaissance,
    codeRace: codeRace,
    libelleRace: RACES[codeRace].nom,
    typeRace: RACES[codeRace].type || null,
    sexe: d.sexe,
    causeEntree: d.causeEntree,
    libelleCauseEntree: CAUSES_ENTREE[d.causeEntree] || d.causeEntree,
    dateEntree: d.dateEntree,
    causeSortie: null,
    libelleCauseSortie: null,
    dateSortie: null,
    mereIPG: mereIPG,
    mereCPB: null,
    pere: pere,
    importedAt: new Date().toISOString(),
    source: 'manuel-v1'
  };

  state.animaux.push(animal);
  bumpVersion('cheptel');
  persist();
  render();
  closeAddModal();
  toast(`${animal.nom || animal.numTravail} ajouté au cheptel`, 'success');
}

// Affiche/masque la date d'entrée selon la cause
function onCauseEntreeChange() {
  const cause = document.getElementById('add-cause-entree').value;
  document.getElementById('row-date-entree').hidden = (cause === 'N');
}

/* ============================================================
   NAVIGATION CHEPTEL <-> SANITAIRE
   ============================================================ */

function switchView(view) {
  state.vue = view;
  document.querySelectorAll('.tab').forEach(t => {
    const isActive = t.dataset.view === view;
    t.classList.toggle('active', isActive);
    t.setAttribute('aria-selected', isActive);
  });
  document.querySelectorAll('.view').forEach(s => {
    s.hidden = (s.dataset.view !== view);
  });
  if (view === 'sanitaire') renderMedList();
}

/* ============================================================
   MÉDICAMENTS — CRUD bibliothèque
   ============================================================
   Modèle : { id, nom, amm, forme, delaiViande, delaiLait, notes,
              createdAt, updatedAt }
   ============================================================ */

const FORMES_LABELS = {
  'injectable': 'Injectable',
  'oral': 'Oral',
  'intra-mammaire': 'Intra-mammaire',
  'intra-uterin': 'Intra-utérin',
  'externe': 'Externe',
  'autre': 'Autre'
};

// Calcul du délai d'attente effectif selon le mode AB.
// Règle bio (CE 889/2008) : doublement du délai conventionnel, avec un
// minimum absolu de 48h. Si le délai conventionnel est 0, l'AB n'impose pas
// de minimum (cas d'un produit naturellement compatible bio).
function delaiEffectif(delaiConventionnel) {
  const conv = parseInt(delaiConventionnel, 10) || 0;
  if (!state.settings.bio) return conv;
  if (conv === 0) return 0;       // pas de doublement si délai d'origine nul
  const doubled = conv * 2;
  return Math.max(doubled, 2);    // minimum 48h = 2 jours
}

function delaiViandeEffectif(med) {
  return delaiEffectif(med.delaiViande);
}

function delaiLaitEffectif(med) {
  return delaiEffectif(med.delaiLait);
}

/* ----- Statut bio d'un animal ----- */
// Référentiel : règlement CE 2018/848 (qui a remplacé le 889/2008).
//
// Pour les bovins viande, la durée de conversion est de 12 mois minimum,
// et au moins 3/4 de la vie de l'animal doit avoir été passée en système bio.
//
// Comportement de l'app :
//   - Mode AB désactivé          → tous les animaux sont "conventionnel"
//   - Mode AB + dateConversion :
//       né avant la conversion   → "conventionnel" tant que pas 3/4 de vie en bio,
//                                  puis "bio" automatiquement
//       né après la conversion   → "bio" dès la naissance
//       acheté après conversion  → "conversion" pendant 12 mois, puis "bio"
//
// Statuts possibles : 'bio' | 'conversion' | 'conventionnel'

function computeBioStatus(animal) {
  if (!state.settings.bio || !state.settings.dateConversion) {
    return { status: 'conventionnel', detail: 'Mode AB non activé', dateBio: null };
  }
  if (!animal.dateNaissance) {
    return { status: 'conventionnel', detail: 'Date de naissance manquante', dateBio: null };
  }

  // Forçage manuel : si l'éleveur a explicitement marqué l'animal comme bio
  // (typique pour un animal acheté déjà bio dans une autre exploitation certifiée)
  // ou comme conventionnel, on respecte ce choix sans calculer.
  if (animal.bioManuel === true) {
    return {
      status: 'bio',
      detail: 'Bio (forcé manuellement — animal acheté bio)',
      dateBio: animal.dateEntree || animal.dateNaissance,
      manuel: true
    };
  }
  if (animal.bioManuel === false) {
    return {
      status: 'conventionnel',
      detail: 'Conventionnel (forcé manuellement)',
      dateBio: null,
      manuel: true
    };
  }

  const dateConv = new Date(state.settings.dateConversion);
  const dateNaiss = new Date(animal.dateNaissance);
  const dateEntree = animal.dateEntree ? new Date(animal.dateEntree) : dateNaiss;
  const today = new Date();

  // ===== Cas 1 : animal NÉ dans l'exploitation bio =====
  // Selon le règlement CE 2018/848 annexe II partie II point 1.2 :
  // un animal né dans une exploitation bio (de mère bio) est BIO DÈS LA NAISSANCE.
  // Il n'y a pas de période de conversion individuelle.
  // Le critère : cause d'entrée = N (naissance) ET date de naissance >= date conversion exploitation.
  if (animal.causeEntree === 'N' && dateNaiss >= dateConv) {
    return {
      status: 'bio',
      detail: 'Né en exploitation bio',
      dateBio: animal.dateNaissance
    };
  }

  // ===== Cas 2 : animal ACHETÉ ou INTRODUIT (CAUSEN = A ou I) =====
  // Période de conversion individuelle : 12 mois ET 75% de vie en bio.
  // Date d'entrée en système bio = date d'entrée dans le cheptel (si après la conversion exploitation)
  // ou date de conversion (si entré avant).
  // ===== Cas 3 : animal NÉ avant la conversion de l'exploitation =====
  // Présent lors du passage en bio. Même logique : 12 mois ET 75%.
  // Date d'entrée en système bio = date de conversion exploitation.
  let dateEntreeBio;
  if ((animal.causeEntree === 'A' || animal.causeEntree === 'I')) {
    dateEntreeBio = dateEntree >= dateConv ? dateEntree : dateConv;
  } else {
    // CAUSEN = N mais né avant la conversion → présent lors de la conversion
    dateEntreeBio = dateConv;
  }

  // Si l'animal n'est pas encore entré en système bio
  if (today < dateEntreeBio) {
    return { status: 'conventionnel', detail: 'Pas encore en système bio', dateBio: null };
  }

  // Calcul des deux conditions cumulatives (CE 2018/848 annexe II)
  const MS_PAR_JOUR = 1000 * 60 * 60 * 24;
  const MOIS_EN_JOURS = 365.25 / 12;
  const joursEnBio = (today - dateEntreeBio) / MS_PAR_JOUR;
  const joursDeVie = (today - dateNaiss) / MS_PAR_JOUR;
  const moisEnBio = joursEnBio / MOIS_EN_JOURS;
  const ratio = joursDeVie > 0 ? joursEnBio / joursDeVie : 0;

  const cond12mois = moisEnBio >= 12;
  const cond75pct = ratio >= 0.75;

  if (cond12mois && cond75pct) {
    return {
      status: 'bio',
      detail: `Bio depuis ${formatDateFR(dateEntreeBio.toISOString().slice(0, 10))} · ${Math.round(ratio * 100)}% de vie en bio`,
      dateBio: dateEntreeBio.toISOString().slice(0, 10)
    };
  }

  // Calcul de la date à laquelle l'animal sera bio :
  // C'est le MAX entre :
  //   - dateEntreeBio + 12 mois
  //   - date où le ratio atteint 0.75
  const tEntreeBio = dateEntreeBio.getTime();
  const tNaiss = dateNaiss.getTime();
  const tCible75 = (tEntreeBio - 0.75 * tNaiss) / 0.25;
  const tCible12mois = tEntreeBio + 12 * MOIS_EN_JOURS * MS_PAR_JOUR;
  const tCible = Math.max(tCible75, tCible12mois);
  const dateBio = new Date(tCible);
  const dateBioISO = dateBio.toISOString().slice(0, 10);

  let critere = '';
  if (!cond12mois && !cond75pct) {
    critere = 'manque les deux conditions (12 mois + 75%)';
  } else if (!cond12mois) {
    critere = `12 mois en bio non atteints (actuellement ${moisEnBio.toFixed(1)} mois)`;
  } else {
    critere = `75% de vie en bio non atteint (actuellement ${Math.round(ratio * 100)}%)`;
  }

  const joursRestants = Math.ceil((dateBio - today) / MS_PAR_JOUR);
  const moisRestants = Math.round(joursRestants / MOIS_EN_JOURS * 10) / 10;

  return {
    status: 'conversion',
    detail: `${critere}. Bio le ${formatDateFR(dateBioISO)} (dans ${moisRestants < 1 ? joursRestants + ' j' : moisRestants + ' mois'})`,
    dateBio: dateBioISO
  };
}

let medSearchQuery = '';
let medEditingId = null; // null = nouveau, sinon id du médicament en cours d'édition

function renderMedList() {
  const list = document.getElementById('med-list');
  const empty = document.getElementById('med-empty');
  const meds = state.medicaments || [];

  if (meds.length === 0) {
    list.innerHTML = '';
    empty.hidden = false;
    return;
  }
  empty.hidden = true;

  // Filtre par recherche
  const q = medSearchQuery.trim().toLowerCase();
  let filtered = meds;
  if (q) {
    filtered = meds.filter(m => {
      const hay = [m.nom, m.amm, m.notes, FORMES_LABELS[m.forme]]
                  .filter(Boolean).join(' ').toLowerCase();
      return hay.includes(q);
    });
  }

  // Tri par nom
  filtered = [...filtered].sort((a, b) => (a.nom || '').localeCompare(b.nom || '', 'fr'));

  if (filtered.length === 0) {
    list.innerHTML = `<p style="color:var(--ink-3);padding:30px;text-align:center">Aucun médicament ne correspond à "${q}".</p>`;
    return;
  }

  list.innerHTML = filtered.map(m => {
    const formeLabel = FORMES_LABELS[m.forme] || (m.forme ? m.forme : '—');
    const ammLabel = m.amm ? `AMM ${m.amm}` : '';
    const metaItems = [formeLabel, ammLabel].filter(Boolean);
    const metaHtml = metaItems.map((s, i) =>
      i > 0 ? '<span class="sep">·</span><span>' + s + '</span>' : '<span>' + s + '</span>'
    ).join(' ');

    // Délais effectifs (avec doublement si exploitation en AB)
    const viandeEff = delaiViandeEffectif(m);
    const laitEff = delaiLaitEffectif(m);
    const isBio = state.settings.bio;
    const viandeDoubled = isBio && m.delaiViande > 0;
    const laitDoubled = isBio && m.delaiLait > 0;

    const viandeHtml = viandeEff > 0
      ? `Viande <strong>${viandeEff} j</strong>${viandeDoubled ? ` <span style="color:var(--vert);font-size:10px">AB ×2</span>` : ''}${viandeDoubled && m.delaiViande !== viandeEff ? ` <span style="color:var(--ink-3);font-size:10px">(conv. ${m.delaiViande} j)</span>` : ''}`
      : '<span class="zero">Viande 0 j</span>';
    const laitHtml = laitEff > 0
      ? `<span class="delai">Lait <strong>${laitEff} j</strong>${laitDoubled ? ` <span style="color:var(--vert);font-size:10px">AB ×2</span>` : ''}</span>`
      : (m.delaiLait === 0 && m.forme === 'intra-mammaire'
          ? '<span class="delai zero">Lait 0 j</span>'
          : '');
    return `
      <div class="med-card" data-id="${m.id}">
        <div>
          <div class="nom">${escapeHtml(m.nom)}</div>
          <div class="meta">${metaHtml || '<span style="color:var(--ink-3)">—</span>'}</div>
          ${m.notes ? `<div class="notes">${escapeHtml(m.notes)}</div>` : ''}
        </div>
        <div class="delais">
          <span class="delai">${viandeHtml}</span>
          ${laitHtml}
        </div>
      </div>
    `;
  }).join('');

  // Liaisons sur les cartes
  list.querySelectorAll('.med-card').forEach(card => {
    card.addEventListener('click', () => openMedModal(card.dataset.id));
  });
}

function escapeHtml(s) {
  if (!s) return '';
  return String(s).replace(/[&<>"']/g, c => ({
    '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
  }[c]));
}

function openMedModal(id) {
  medEditingId = id || null;
  const m = id ? state.medicaments.find(x => x.id === id) : null;

  document.getElementById('med-modal-title').textContent =
    m ? 'Modifier le médicament' : 'Nouveau médicament';
  document.getElementById('med-nom').value = m?.nom || '';
  document.getElementById('med-amm').value = m?.amm || '';
  document.getElementById('med-forme').value = m?.forme || '';
  document.getElementById('med-delai-viande').value = m?.delaiViande ?? 0;
  document.getElementById('med-delai-lait').value = m?.delaiLait ?? 0;
  document.getElementById('med-notes').value = m?.notes || '';
  document.getElementById('med-delete').hidden = !m;

  document.querySelectorAll('#med-modal-bg .form-error').forEach(e => e.hidden = true);
  document.querySelectorAll('#med-modal-bg [aria-invalid="true"]').forEach(e => e.removeAttribute('aria-invalid'));

  document.getElementById('med-modal-bg').classList.add('show');
  setTimeout(() => document.getElementById('med-nom').focus(), 50);
}

function closeMedModal() {
  document.getElementById('med-modal-bg').classList.remove('show');
}

function saveMedicament() {
  const nom = document.getElementById('med-nom').value.trim();
  // Reset erreurs
  document.querySelectorAll('#med-modal-bg .form-error').forEach(e => e.hidden = true);
  document.querySelectorAll('#med-modal-bg [aria-invalid="true"]').forEach(e => e.removeAttribute('aria-invalid'));

  if (!nom) {
    document.getElementById('med-nom').setAttribute('aria-invalid', 'true');
    const err = document.getElementById('err-med-nom');
    err.textContent = 'Le nom commercial est obligatoire.';
    err.hidden = false;
    return;
  }

  const amm = document.getElementById('med-amm').value.trim() || null;
  const forme = document.getElementById('med-forme').value || null;
  const delaiViande = Math.max(0, parseInt(document.getElementById('med-delai-viande').value, 10) || 0);
  const delaiLait = Math.max(0, parseInt(document.getElementById('med-delai-lait').value, 10) || 0);
  const notes = document.getElementById('med-notes').value.trim() || null;

  // Détection de doublon par nom
  const lcNom = nom.toLowerCase();
  const duplicate = state.medicaments.find(m =>
    m.nom.toLowerCase() === lcNom && m.id !== medEditingId
  );
  if (duplicate) {
    if (!confirm(`Un médicament nommé "${duplicate.nom}" existe déjà. Continuer ?`)) return;
  }

  const now = new Date().toISOString();

  if (medEditingId) {
    // Édition
    const med = state.medicaments.find(m => m.id === medEditingId);
    if (med) {
      med.nom = nom;
      med.amm = amm;
      med.forme = forme;
      med.delaiViande = delaiViande;
      med.delaiLait = delaiLait;
      med.notes = notes;
      med.updatedAt = now;
    }
  } else {
    // Création
    state.medicaments.push({
      id: 'med-' + Date.now() + '-' + Math.random().toString(36).slice(2, 7),
      nom,
      amm,
      forme,
      delaiViande,
      delaiLait,
      notes,
      createdAt: now,
      updatedAt: now
    });
  }

  bumpVersion('medicaments');
  persist();
  renderMedList();
  closeMedModal();
  toast(medEditingId ? 'Médicament mis à jour' : 'Médicament ajouté', 'success');
}

function deleteMedicament() {
  if (!medEditingId) return;
  const med = state.medicaments.find(m => m.id === medEditingId);
  if (!med) return;
  if (!confirm(`Supprimer "${med.nom}" de la bibliothèque ?\n\nCette action est irréversible. Les soins déjà enregistrés avec ce médicament conserveront leur trace.`)) return;
  state.medicaments = state.medicaments.filter(m => m.id !== medEditingId);
  bumpVersion('medicaments');
  persist();
  renderMedList();
  closeMedModal();
  toast(`${med.nom} supprimé`);
}

/* ============================================================
   ORDONNANCES — CRUD + photo
   ============================================================
   Modèle : {
     id, date (ISO), veterinaire (string), numero,
     photo: { dataUrl (base64 jpeg), width, height, sizeKb } | null,
     prescriptions: [{ medicamentId, posologie, ciblesPrevues, notes }],
     notes,
     createdAt, updatedAt
   }
   ============================================================ */

let ordSearchQuery = '';
let ordEditingId = null; // null = nouveau, sinon id de l'ordonnance en cours d'édition
// Brouillon de la photo en cours dans le formulaire (avant enregistrement)
let ordPhotoDraft = null;

function renderOrdList() {
  const list = document.getElementById('ord-list');
  const empty = document.getElementById('ord-empty');
  const ords = state.ordonnances || [];

  if (ords.length === 0) {
    list.innerHTML = '';
    empty.hidden = false;
    return;
  }
  empty.hidden = true;

  // Filtre par recherche
  const q = ordSearchQuery.trim().toLowerCase();
  let filtered = ords;
  if (q) {
    filtered = ords.filter(o => {
      const medsNames = (o.prescriptions || [])
        .map(p => {
          const med = state.medicaments.find(m => m.id === p.medicamentId);
          return med ? med.nom : '';
        })
        .filter(Boolean)
        .join(' ');
      const hay = [o.veterinaire, o.numero, o.notes, medsNames]
                  .filter(Boolean).join(' ').toLowerCase();
      return hay.includes(q);
    });
  }

  // Tri par date desc (plus récent en premier)
  filtered = [...filtered].sort((a, b) => (b.date || '').localeCompare(a.date || ''));

  if (filtered.length === 0) {
    list.innerHTML = `<p style="color:var(--ink-3);padding:30px;text-align:center">Aucune ordonnance ne correspond à "${escapeHtml(q)}".</p>`;
    return;
  }

  // Regroupement par mois
  const groups = {};
  for (const o of filtered) {
    const d = new Date(o.date);
    const key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    (groups[key] = groups[key] || []).push(o);
  }

  const moisFR = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin',
                  'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'];
  const sortedKeys = Object.keys(groups).sort((a, b) => b.localeCompare(a));

  let html = '';
  for (const k of sortedKeys) {
    const [y, m] = k.split('-');
    html += `<div class="ord-month-header">${moisFR[parseInt(m, 10) - 1]} ${y}</div>`;
    for (const o of groups[k]) {
      const thumb = o.photo?.dataUrl
        ? `<img class="thumb" src="${o.photo.dataUrl}" alt="">`
        : `<div class="thumb-empty">📄</div>`;

      // Pills des médicaments prescrits
      const medsPills = (o.prescriptions || [])
        .map(p => {
          const med = state.medicaments.find(m => m.id === p.medicamentId);
          return med ? `<span class="pill">${escapeHtml(med.nom)}</span>` : '';
        })
        .filter(Boolean).join('');

      html += `
        <div class="ord-card" data-id="${o.id}">
          ${thumb}
          <div class="info">
            <div class="head">
              <div class="veto">${escapeHtml(o.veterinaire || '—')}</div>
              <div class="date">${formatDateFR(o.date)}</div>
            </div>
            ${medsPills ? `<div class="meds">${medsPills}</div>` : '<div class="meds" style="font-style:italic;color:var(--ink-3)">Aucun médicament listé</div>'}
            ${o.numero ? `<div class="num">N° ${escapeHtml(o.numero)}</div>` : ''}
          </div>
        </div>
      `;
    }
  }
  list.innerHTML = html;

  // Liaisons : clic sur une carte ouvre l'édition, clic sur la photo ouvre le zoom
  list.querySelectorAll('.ord-card').forEach(card => {
    card.addEventListener('click', (e) => {
      // Si on a cliqué sur la miniature, ouvre le zoom au lieu de l'édition
      if (e.target.classList.contains('thumb')) {
        e.stopPropagation();
        openPhotoZoom(e.target.src);
        return;
      }
      openOrdModal(card.dataset.id);
    });
  });
}

function openOrdModal(id) {
  ordEditingId = id || null;
  const o = id ? state.ordonnances.find(x => x.id === id) : null;

  document.getElementById('ord-modal-title').textContent =
    o ? 'Modifier l\'ordonnance' : 'Nouvelle ordonnance';
  document.getElementById('ord-date').value = o?.date || new Date().toISOString().slice(0, 10);
  document.getElementById('ord-veto').value = o?.veterinaire || '';
  document.getElementById('ord-numero').value = o?.numero || '';
  document.getElementById('ord-notes').value = o?.notes || '';
  document.getElementById('ord-delete').hidden = !o;

  // Reset des erreurs
  document.querySelectorAll('#ord-modal-bg .form-error').forEach(e => e.hidden = true);
  document.querySelectorAll('#ord-modal-bg [aria-invalid="true"]').forEach(e => e.removeAttribute('aria-invalid'));

  // Photo
  ordPhotoDraft = o?.photo ? { ...o.photo } : null;
  refreshOrdPhotoUI();

  // Prescriptions
  const container = document.getElementById('ord-prescriptions');
  container.innerHTML = '';
  if (o && o.prescriptions && o.prescriptions.length > 0) {
    for (const p of o.prescriptions) {
      addPrescriptionLine(p);
    }
  } else {
    addPrescriptionLine();
  }

  document.getElementById('ord-modal-bg').classList.add('show');
  setTimeout(() => document.getElementById('ord-veto').focus(), 50);
}

function closeOrdModal() {
  document.getElementById('ord-modal-bg').classList.remove('show');
  ordPhotoDraft = null;
}

function refreshOrdPhotoUI() {
  const empty = document.getElementById('ord-photo-empty');
  const preview = document.getElementById('ord-photo-preview');
  if (ordPhotoDraft && ordPhotoDraft.dataUrl) {
    empty.hidden = true;
    preview.hidden = false;
    document.getElementById('ord-photo-img').src = ordPhotoDraft.dataUrl;
    document.getElementById('ord-photo-info').textContent =
      `${ordPhotoDraft.width}×${ordPhotoDraft.height} px · ${ordPhotoDraft.sizeKb} ko`;
  } else {
    empty.hidden = false;
    preview.hidden = true;
  }
}

// Compression et stockage d'une photo en base64 (max 1200 px largeur, jpeg qualité 0.82)
async function handleOrdPhoto(file) {
  if (!file || !file.type.startsWith('image/')) {
    toast('Fichier image attendu', 'error');
    return;
  }
  try {
    const dataUrl = await new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result);
      reader.onerror = () => reject(new Error('Lecture impossible'));
      reader.readAsDataURL(file);
    });
    const img = await new Promise((resolve, reject) => {
      const i = new Image();
      i.onload = () => resolve(i);
      i.onerror = () => reject(new Error('Image illisible'));
      i.src = dataUrl;
    });
    // Compression sur canvas
    const MAX_W = 1200;
    let w = img.width, h = img.height;
    if (w > MAX_W) {
      h = Math.round(h * (MAX_W / w));
      w = MAX_W;
    }
    const canvas = document.createElement('canvas');
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0, w, h);
    const compressedDataUrl = canvas.toDataURL('image/jpeg', 0.82);
    const sizeKb = Math.round(compressedDataUrl.length * 0.75 / 1024); // estimation base64 → bytes
    ordPhotoDraft = {
      dataUrl: compressedDataUrl,
      width: w,
      height: h,
      sizeKb: sizeKb
    };
    refreshOrdPhotoUI();
  } catch (e) {
    toast('Erreur photo : ' + e.message, 'error');
  }
}

// Ajoute une ligne de prescription (vide ou pré-remplie)
function addPrescriptionLine(prescription) {
  const container = document.getElementById('ord-prescriptions');
  const idx = container.children.length;
  const line = document.createElement('div');
  line.className = 'prescription-line';
  line.dataset.idx = idx;

  // Liste des options médicaments
  const meds = [...state.medicaments].sort((a, b) => (a.nom || '').localeCompare(b.nom || '', 'fr'));
  const medOptions = ['<option value="">— Choisir un médicament —</option>']
    .concat(meds.map(m => {
      const selected = (prescription?.medicamentId === m.id) ? ' selected' : '';
      return `<option value="${m.id}"${selected}>${escapeHtml(m.nom)}</option>`;
    }))
    .join('');

  line.innerHTML = `
    <div class="line-head">
      <span class="num">Médicament ${idx + 1}</span>
      <button type="button" title="Retirer cette ligne">✕</button>
    </div>
    <div class="row">
      <label>Médicament</label>
      <select class="presc-med">${medOptions}</select>
    </div>
    <div class="row">
      <label>Posologie</label>
      <input type="text" class="presc-posologie" placeholder="ex: 5 ml SC pendant 3 jours" maxlength="200" value="${escapeHtml(prescription?.posologie || '')}">
    </div>
    <div class="row">
      <label>Cibles prévues</label>
      <input type="text" class="presc-cibles" placeholder="ex: BERTRAND, BISON (texte libre)" maxlength="200" value="${escapeHtml(prescription?.ciblesPrevues || '')}">
    </div>
  `;
  container.appendChild(line);

  // Bouton de suppression
  line.querySelector('.line-head button').addEventListener('click', () => {
    if (container.children.length === 1) {
      // Ne supprime pas la dernière ligne, juste la vide
      line.querySelector('.presc-med').value = '';
      line.querySelector('.presc-posologie').value = '';
      line.querySelector('.presc-cibles').value = '';
    } else {
      line.remove();
      // Renumérote les lignes restantes
      Array.from(container.children).forEach((l, i) => {
        l.querySelector('.line-head .num').textContent = `Médicament ${i + 1}`;
        l.dataset.idx = i;
      });
    }
  });
}

// Enregistrement de l'ordonnance
function saveOrdonnance() {
  // Reset erreurs
  document.querySelectorAll('#ord-modal-bg .form-error').forEach(e => e.hidden = true);
  document.querySelectorAll('#ord-modal-bg [aria-invalid="true"]').forEach(e => e.removeAttribute('aria-invalid'));

  const date = document.getElementById('ord-date').value;
  const veto = document.getElementById('ord-veto').value.trim();
  const numero = document.getElementById('ord-numero').value.trim() || null;
  const notes = document.getElementById('ord-notes').value.trim() || null;

  let hasError = false;
  if (!date) {
    showFieldError('ord-date', 'err-ord-date', 'La date est obligatoire.');
    hasError = true;
  } else {
    const d = new Date(date);
    const today = new Date();
    today.setHours(23, 59, 59);
    if (d > today) {
      showFieldError('ord-date', 'err-ord-date', 'La date ne peut pas être dans le futur.');
      hasError = true;
    }
  }
  if (!veto) {
    showFieldError('ord-veto', 'err-ord-veto', 'Le vétérinaire est obligatoire.');
    hasError = true;
  }
  if (hasError) return;

  // Construction des prescriptions (on filtre les lignes vides)
  const lines = document.querySelectorAll('#ord-prescriptions .prescription-line');
  const prescriptions = [];
  for (const line of lines) {
    const medId = line.querySelector('.presc-med').value;
    const posologie = line.querySelector('.presc-posologie').value.trim();
    const cibles = line.querySelector('.presc-cibles').value.trim();
    // Garde la ligne seulement si au moins un médicament OU un texte est rempli
    if (medId || posologie || cibles) {
      prescriptions.push({
        medicamentId: medId || null,
        posologie: posologie || null,
        ciblesPrevues: cibles || null,
        notes: null
      });
    }
  }

  const now = new Date().toISOString();
  if (ordEditingId) {
    const ord = state.ordonnances.find(o => o.id === ordEditingId);
    if (ord) {
      ord.date = date;
      ord.veterinaire = veto;
      ord.numero = numero;
      ord.photo = ordPhotoDraft ? { ...ordPhotoDraft } : null;
      ord.prescriptions = prescriptions;
      ord.notes = notes;
      ord.updatedAt = now;
    }
  } else {
    state.ordonnances.push({
      id: 'ord-' + Date.now() + '-' + Math.random().toString(36).slice(2, 7),
      date,
      veterinaire: veto,
      numero,
      photo: ordPhotoDraft ? { ...ordPhotoDraft } : null,
      prescriptions,
      notes,
      createdAt: now,
      updatedAt: now
    });
  }

  bumpVersion('ordonnances');
  persist();
  renderOrdList();
  closeOrdModal();
  toast(ordEditingId ? 'Ordonnance mise à jour' : 'Ordonnance enregistrée', 'success');
}

function deleteOrdonnance() {
  if (!ordEditingId) return;
  const ord = state.ordonnances.find(o => o.id === ordEditingId);
  if (!ord) return;

  // Garde-fou : si des soins seront liés à cette ordonnance (préparation v0.19)
  const soinsLies = (state.soins || []).filter(s => s.ordonnanceId === ordEditingId);
  let msg = `Supprimer l'ordonnance du ${formatDateFR(ord.date)} (${ord.veterinaire}) ?\n\nCette action est irréversible.`;
  if (soinsLies.length > 0) {
    msg += `\n\n⚠ Attention : ${soinsLies.length} soin${soinsLies.length > 1 ? 's' : ''} ${soinsLies.length > 1 ? 'sont rattachés' : 'est rattaché'} à cette ordonnance. Le rattachement sera perdu mais les soins seront conservés.`;
  }
  if (!confirm(msg)) return;

  state.ordonnances = state.ordonnances.filter(o => o.id !== ordEditingId);
  bumpVersion('ordonnances');
  persist();
  renderOrdList();
  closeOrdModal();
  toast('Ordonnance supprimée');
}

// Photo plein écran
function openPhotoZoom(dataUrl) {
  document.getElementById('photo-zoom-img').src = dataUrl;
  document.getElementById('photo-zoom-bg').classList.add('show');
}

function closePhotoZoom() {
  document.getElementById('photo-zoom-bg').classList.remove('show');
}

/* ============================================================
   RÉGLAGES DE L'EXPLOITATION
   ============================================================ */

function openSettingsModal() {
  const wasBio = state.settings.bio;
  const bioCheckbox = document.getElementById('settings-bio');
  const dateInput = document.getElementById('settings-date-conversion');
  const conversionBlock = document.getElementById('conversion-date-block');

  bioCheckbox.checked = wasBio;
  dateInput.value = state.settings.dateConversion || '';
  conversionBlock.hidden = !wasBio;
  document.getElementById('bio-warning').hidden = true;

  // Toggle de visibilité du bloc date selon la coche bio
  bioCheckbox.onchange = function () {
    conversionBlock.hidden = !this.checked;
    document.getElementById('bio-warning').hidden = (this.checked === wasBio);
  };

  document.getElementById('settings-modal-bg').classList.add('show');
}

function closeSettingsModal() {
  document.getElementById('settings-modal-bg').classList.remove('show');
}

function saveSettings() {
  const newBio = document.getElementById('settings-bio').checked;
  const newDateConv = document.getElementById('settings-date-conversion').value || null;
  const wasBio = state.settings.bio;
  const wasDate = state.settings.dateConversion;

  // Validation : si bio coché, date conversion obligatoire
  if (newBio && !newDateConv) {
    toast('Indique la date de conversion de ton exploitation', 'error');
    return;
  }

  state.settings.bio = newBio;
  state.settings.dateConversion = newDateConv;
  if (newBio !== wasBio || newDateConv !== wasDate) {
    bumpVersion('settings');
  }
  persist();

  // Re-render les vues impactées
  render(); // pour les pastilles bio dans la liste
  if (state.vue === 'sanitaire') renderMedList();

  closeSettingsModal();

  if (newBio !== wasBio) {
    toast(newBio ? 'Mode AB activé : délais doublés' : 'Mode AB désactivé', 'success');
  } else if (newDateConv !== wasDate) {
    toast('Date de conversion mise à jour', 'success');
  } else {
    toast('Réglages enregistrés');
  }
}

/* ============================================================
   TOAST
   ============================================================ */

let toastTimer;
function toast(msg, kind) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (kind ? ' ' + kind : '');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { t.className = 'toast'; }, 3500);
}

/* ============================================================
   CLOUD — Configuration et providers
   ============================================================
   Architecture : un provider = { connect, disconnect, save, list, load, isConnected }
   Pour ajouter Dropbox / OneDrive plus tard, créer un nouvel objet
   conforme à la même interface et l'enregistrer dans CLOUD_PROVIDERS.
   ============================================================ */

// ⚠️ CONFIGURATION REQUISE
// Pour activer Google Drive :
// 1. Créer un projet sur https://console.cloud.google.com/
// 2. Activer "Google Drive API" et "Google Identity Services"
// 3. Créer un identifiant OAuth client ID type "Application web"
// 4. Ajouter ton domaine GitHub Pages dans les origines JavaScript autorisées
// 5. Coller le Client ID ci-dessous
const GOOGLE_CLIENT_ID = '635142647896-eo163p9l70igkcjf5ue6r16e153ss0bm.apps.googleusercontent.com';

const CLOUD_STORAGE_KEY = 'carnet-cloud-config-v1';
const CLOUD_FOLDER_NAME = 'Carnet Sanitaire';

// État cloud global
const cloudState = {
  provider: null,        // 'google-drive' | null
  // 'disconnected' | 'connected' | 'syncing' | 'error' | 'needs_reconnect'
  status: 'disconnected',
  lastSync: null,        // ISO date dernière sauvegarde réussie
  errorMessage: null,
  pendingSaveTimer: null,
  folderId: null,        // ID du dossier "Carnet Sanitaire" sur Drive
  dirty: false,          // true s'il y a des modifs non synchronisées vers le cloud
  reconciling: false     // true pendant la modal de réconciliation post-connexion (bloque les syncs)
};

function loadCloudConfig() {
  try {
    const raw = localStorage.getItem(CLOUD_STORAGE_KEY);
    if (!raw) return;
    const cfg = JSON.parse(raw);
    cloudState.provider = cfg.provider || null;
    cloudState.lastSync = cfg.lastSync || null;
    cloudState.folderId = cfg.folderId || null;
  } catch (e) { /* silent */ }
}

function saveCloudConfig() {
  try {
    localStorage.setItem(CLOUD_STORAGE_KEY, JSON.stringify({
      provider: cloudState.provider,
      lastSync: cloudState.lastSync,
      folderId: cloudState.folderId
    }));
  } catch (e) { /* silent */ }
}

/* ----- Provider Google Drive ----- */

const GoogleDriveProvider = {
  name: 'Google Drive',
  id: 'google-drive',
  scope: 'https://www.googleapis.com/auth/drive.file',
  tokenClient: null,
  accessToken: null,
  tokenExpiresAt: 0,
  gisLoaded: false,

  // Clé localStorage : token persisté entre fermetures de navigateur.
  // Note : on utilise localStorage et non sessionStorage parce que la politique
  // Cross-Origin-Opener-Policy de GitHub Pages bloque la négociation silencieuse
  // d'OAuth. Sans cache persistant, on aurait une popup à chaque rafraîchissement.
  // Le token Google reste valide ~1h ; au-delà, popup explicite.
  _TOKEN_KEY: 'carnet-google-token-v1',

  isAvailable() {
    return GOOGLE_CLIENT_ID && GOOGLE_CLIENT_ID.length > 10;
  },

  // Sauvegarde du token. Permet de F5, fermer/rouvrir onglet, fermer/rouvrir
  // navigateur sans devoir reposer une popup OAuth tant que le token est valide.
  _persistToken() {
    try {
      if (this.accessToken && this.tokenExpiresAt > Date.now()) {
        localStorage.setItem(this._TOKEN_KEY, JSON.stringify({
          accessToken: this.accessToken,
          tokenExpiresAt: this.tokenExpiresAt
        }));
      }
    } catch (e) { /* silent */ }
  },

  _loadPersistedToken() {
    try {
      const raw = localStorage.getItem(this._TOKEN_KEY);
      if (!raw) return false;
      const data = JSON.parse(raw);
      // 60 sec de marge pour éviter d'utiliser un token quasi-expiré
      if (data.accessToken && data.tokenExpiresAt > Date.now() + 60000) {
        this.accessToken = data.accessToken;
        this.tokenExpiresAt = data.tokenExpiresAt;
        return true;
      }
      // Token expiré : on nettoie
      localStorage.removeItem(this._TOKEN_KEY);
    } catch (e) { /* silent */ }
    return false;
  },

  _clearPersistedToken() {
    try { localStorage.removeItem(this._TOKEN_KEY); } catch (e) {}
  },

  // Charge le SDK Google Identity Services à la demande (lazy load)
  async _loadGIS() {
    if (this.gisLoaded) return;
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = 'https://accounts.google.com/gsi/client';
      script.async = true;
      script.defer = true;
      script.onload = () => {
        this.gisLoaded = true;
        resolve();
      };
      script.onerror = () => reject(new Error('Impossible de charger Google Identity Services'));
      document.head.appendChild(script);
    });
  },

  async _ensureToken(interactive = true) {
    // 1. Token déjà en mémoire et valide
    if (this.accessToken && Date.now() < this.tokenExpiresAt - 60000) {
      return this.accessToken;
    }
    // 2. Token persisté en sessionStorage (autre onglet ou rafraîchissement de la page)
    if (this._loadPersistedToken()) {
      return this.accessToken;
    }
    await this._loadGIS();

    // Helper pour faire une demande de token. promptMode = '' (interactif) ou 'none' (silencieux).
    // IMPORTANT : un mode interactif ('') ne peut être déclenché QUE dans la chaîne
    // d'événements d'un clic utilisateur direct. Sinon Chrome/Safari bloquent la popup.
    const self = this; // capture explicite pour éviter tout problème de contexte dans les callbacks
    const tryRequest = (promptMode) => new Promise((resolve, reject) => {
      try {
        self.tokenClient = google.accounts.oauth2.initTokenClient({
          client_id: GOOGLE_CLIENT_ID,
          scope: self.scope,
          callback: (resp) => {
            if (resp.error) {
              reject(new Error(resp.error_description || resp.error));
              return;
            }
            self.accessToken = resp.access_token;
            self.tokenExpiresAt = Date.now() + (resp.expires_in * 1000);
            self._persistToken(); // sauvegarde du token pour les sessions ultérieures
            resolve(self.accessToken);
          },
          error_callback: (err) => {
            // err.type peut valoir : "popup_failed_to_open", "popup_closed",
            // "unknown" (souvent = interaction_required en mode silencieux).
            const msg = err.message || err.type || 'OAuth annulé';
            const e = new Error(msg);
            e.errorType = err.type;
            reject(e);
          }
        });
        self.tokenClient.requestAccessToken({ prompt: promptMode });
      } catch (e) {
        reject(e);
      }
    });

    if (!interactive) {
      // Mode silencieux : on tente sans popup. Si Google refuse, on lève une
      // erreur typée NEED_RECONNECT que l'UI doit gérer en proposant un
      // bouton de reconnexion explicite (qui sera, lui, dans une chaîne de clic).
      try {
        return await tryRequest('none');
      } catch (e) {
        const reconnectErr = new Error('NEED_RECONNECT');
        reconnectErr.code = 'NEED_RECONNECT';
        reconnectErr.original = e;
        throw reconnectErr;
      }
    }
    // Mode interactif : popup directe. À utiliser UNIQUEMENT dans une chaîne de clic.
    return await tryRequest('');
  },

  async connect() {
    if (!this.isAvailable()) {
      throw new Error('Google Drive n\'est pas configuré (CLIENT_ID manquant). Voir les commentaires dans le code source.');
    }
    await this._ensureToken(true);
    // Trouve ou crée le dossier "Carnet Sanitaire"
    cloudState.folderId = await this._findOrCreateFolder();
    return true;
  },

  disconnect() {
    if (this.accessToken && window.google?.accounts?.oauth2) {
      try { google.accounts.oauth2.revoke(this.accessToken, () => {}); } catch (e) {}
    }
    this.accessToken = null;
    this.tokenExpiresAt = 0;
    this._clearPersistedToken();
  },

  async _api(path, options = {}) {
    await this._ensureToken(false);
    let res = await fetch('https://www.googleapis.com/' + path, {
      ...options,
      headers: {
        'Authorization': 'Bearer ' + this.accessToken,
        ...(options.headers || {})
      }
    });
    // Si le serveur Google répond 401 (token invalide / révoqué côté serveur
    // alors qu'on le pensait encore valide), on force un nouveau token et on
    // rejoue la requête une seule fois.
    if (res.status === 401) {
      this.accessToken = null;
      this.tokenExpiresAt = 0;
      this._clearPersistedToken();
      await this._ensureToken(false);
      res = await fetch('https://www.googleapis.com/' + path, {
        ...options,
        headers: {
          'Authorization': 'Bearer ' + this.accessToken,
          ...(options.headers || {})
        }
      });
    }
    if (!res.ok) {
      const text = await res.text();
      throw new Error(`Drive API ${res.status} : ${text.slice(0, 200)}`);
    }
    return res;
  },

  async _findOrCreateFolder() {
    // Cherche le dossier
    const q = encodeURIComponent(
      `name='${CLOUD_FOLDER_NAME}' and mimeType='application/vnd.google-apps.folder' and trashed=false`
    );
    const findRes = await this._api(`drive/v3/files?q=${q}&fields=files(id,name)`);
    const findData = await findRes.json();
    if (findData.files && findData.files.length > 0) {
      return findData.files[0].id;
    }
    // Crée
    const createRes = await this._api('drive/v3/files', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: CLOUD_FOLDER_NAME,
        mimeType: 'application/vnd.google-apps.folder'
      })
    });
    const created = await createRes.json();
    return created.id;
  },

  // Liste les sauvegardes existantes dans le dossier
  // ===== API multi-fichiers (v0.18) =====

  // Trouve un fichier dans le dossier carnet par son nom. Retourne {id, modifiedTime, size} ou null.
  async findFile(filename, parentId) {
    if (!parentId) parentId = cloudState.folderId;
    if (!parentId) return null;
    const q = encodeURIComponent(
      `name='${filename.replace(/'/g, "\\'")}' and '${parentId}' in parents and trashed=false`
    );
    const res = await this._api(
      `drive/v3/files?q=${q}&fields=files(id,name,modifiedTime,size,mimeType)`
    );
    const data = await res.json();
    return (data.files && data.files[0]) || null;
  },

  // Trouve ou crée le sous-dossier "photos" dans le dossier carnet
  async _findOrCreatePhotosFolder() {
    if (this._photosFolderId) return this._photosFolderId;
    if (!cloudState.folderId) {
      cloudState.folderId = await this._findOrCreateFolder();
    }
    const q = encodeURIComponent(
      `name='photos' and '${cloudState.folderId}' in parents and mimeType='application/vnd.google-apps.folder' and trashed=false`
    );
    const res = await this._api(`drive/v3/files?q=${q}&fields=files(id)`);
    const data = await res.json();
    if (data.files && data.files[0]) {
      this._photosFolderId = data.files[0].id;
      return this._photosFolderId;
    }
    // Création
    const createRes = await this._api(`drive/v3/files`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: 'photos',
        mimeType: 'application/vnd.google-apps.folder',
        parents: [cloudState.folderId]
      })
    });
    const created = await createRes.json();
    this._photosFolderId = created.id;
    return this._photosFolderId;
  },

  // Sauvegarde un JSON nommé dans le dossier carnet (crée ou met à jour)
  async saveFile(filename, jsonContent) {
    if (!cloudState.folderId) {
      cloudState.folderId = await this._findOrCreateFolder();
    }
    const existing = await this.findFile(filename, cloudState.folderId);
    return await this._uploadMultipart(filename, jsonContent, 'application/json',
      cloudState.folderId, existing?.id);
  },

  // Lit le contenu texte d'un fichier nommé. Retourne null si absent.
  async loadFile(filename) {
    if (!cloudState.folderId) {
      cloudState.folderId = await this._findOrCreateFolder();
    }
    const f = await this.findFile(filename, cloudState.folderId);
    if (!f) return null;
    const res = await this._api(`drive/v3/files/${f.id}?alt=media`);
    return await res.text();
  },

  // Sauvegarde une photo (dataUrl base64) dans photos/ sous le nom photoId.jpg
  async savePhoto(photoId, dataUrl) {
    const photosFolderId = await this._findOrCreatePhotosFolder();
    const filename = photoId + '.jpg';
    const existing = await this.findFile(filename, photosFolderId);
    // Convertir dataUrl en Blob binaire
    const base64 = dataUrl.split(',')[1];
    const binaryString = atob(base64);
    const bytes = new Uint8Array(binaryString.length);
    for (let i = 0; i < binaryString.length; i++) {
      bytes[i] = binaryString.charCodeAt(i);
    }
    const blob = new Blob([bytes], { type: 'image/jpeg' });
    return await this._uploadBinary(filename, blob, 'image/jpeg', photosFolderId, existing?.id);
  },

  // Charge une photo depuis Drive et retourne son dataUrl base64
  async loadPhoto(photoId) {
    const photosFolderId = await this._findOrCreatePhotosFolder();
    const filename = photoId + '.jpg';
    const f = await this.findFile(filename, photosFolderId);
    if (!f) return null;
    const res = await this._api(`drive/v3/files/${f.id}?alt=media`);
    const blob = await res.blob();
    return await new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result);
      reader.onerror = () => reject(new Error('Lecture photo impossible'));
      reader.readAsDataURL(blob);
    });
  },

  // Liste les photos sur Drive (juste les noms, pour comparer avec le local)
  async listPhotos() {
    const photosFolderId = await this._findOrCreatePhotosFolder();
    const q = encodeURIComponent(
      `'${photosFolderId}' in parents and trashed=false and mimeType='image/jpeg'`
    );
    const res = await this._api(
      `drive/v3/files?q=${q}&fields=files(id,name,size,modifiedTime)&pageSize=1000`
    );
    const data = await res.json();
    return (data.files || []).map(f => ({
      id: f.id,
      photoId: f.name.replace(/\.jpg$/, ''),
      name: f.name,
      modifiedTime: f.modifiedTime,
      size: parseInt(f.size, 10) || 0
    }));
  },

  // Supprime une photo par son photoId
  async deletePhoto(photoId) {
    const photosFolderId = await this._findOrCreatePhotosFolder();
    const filename = photoId + '.jpg';
    const f = await this.findFile(filename, photosFolderId);
    if (f) await this._api(`drive/v3/files/${f.id}`, { method: 'DELETE' });
  },

  // Helper interne : upload multipart pour text/JSON
  async _uploadMultipart(filename, content, mimeType, parentId, existingId) {
    const metadata = existingId
      ? { name: filename }
      : { name: filename, parents: [parentId] };
    const boundary = '-------carnetsanitaire' + Math.random().toString(36).slice(2);
    const delim = '\r\n--' + boundary + '\r\n';
    const closeDelim = '\r\n--' + boundary + '--';
    const body =
      delim +
      'Content-Type: application/json; charset=UTF-8\r\n\r\n' +
      JSON.stringify(metadata) +
      delim +
      `Content-Type: ${mimeType}\r\n\r\n` +
      content +
      closeDelim;
    const url = existingId
      ? `upload/drive/v3/files/${existingId}?uploadType=multipart`
      : `upload/drive/v3/files?uploadType=multipart`;
    const method = existingId ? 'PATCH' : 'POST';
    await this._api(url, {
      method,
      headers: { 'Content-Type': `multipart/related; boundary=${boundary}` },
      body
    });
  },

  // Helper interne : upload binaire pour photos. Utilise le format multipart compatible Drive.
  async _uploadBinary(filename, blob, mimeType, parentId, existingId) {
    const metadata = existingId
      ? { name: filename }
      : { name: filename, parents: [parentId] };
    const boundary = '-------carnetsanitaire' + Math.random().toString(36).slice(2);
    const delim = '\r\n--' + boundary + '\r\n';
    const closeDelim = '\r\n--' + boundary + '--';

    // Construction d'un body multipart binaire via Blob
    const metadataPart = delim +
      'Content-Type: application/json; charset=UTF-8\r\n\r\n' +
      JSON.stringify(metadata);
    const binaryHeader = delim +
      `Content-Type: ${mimeType}\r\n` +
      'Content-Transfer-Encoding: binary\r\n\r\n';
    const body = new Blob([metadataPart, binaryHeader, blob, closeDelim], {
      type: `multipart/related; boundary=${boundary}`
    });

    const url = existingId
      ? `upload/drive/v3/files/${existingId}?uploadType=multipart`
      : `upload/drive/v3/files?uploadType=multipart`;
    const method = existingId ? 'PATCH' : 'POST';
    await this._api(url, {
      method,
      headers: { 'Content-Type': `multipart/related; boundary=${boundary}` },
      body
    });
  },

  // ===== API legacy (v0.17 et avant — pour migration) =====

  async list() {
    if (!cloudState.folderId) {
      cloudState.folderId = await this._findOrCreateFolder();
    }
    const q = encodeURIComponent(
      `'${cloudState.folderId}' in parents and trashed=false and mimeType='application/json'`
    );
    const res = await this._api(
      `drive/v3/files?q=${q}&fields=files(id,name,modifiedTime,size)&orderBy=modifiedTime desc&pageSize=100`
    );
    const data = await res.json();
    return (data.files || []).map(f => ({
      id: f.id,
      name: f.name,
      modifiedTime: f.modifiedTime,
      size: parseInt(f.size, 10) || 0
    }));
  },

  // Upload un JSON dans le dossier (crée ou écrase si même nom) - legacy v0.17
  async save(filename, jsonContent) {
    return await this.saveFile(filename, jsonContent);
  },

  async load(fileId) {
    const res = await this._api(`drive/v3/files/${fileId}?alt=media`);
    return await res.text();
  },

  async delete(fileId) {
    await this._api(`drive/v3/files/${fileId}`, { method: 'DELETE' });
  }
};

// Registre des providers
const CLOUD_PROVIDERS = {
  'google-drive': GoogleDriveProvider
};

function getProvider() {
  return cloudState.provider ? CLOUD_PROVIDERS[cloudState.provider] : null;
}

/* ----- Logique de sauvegarde multi-fichiers (v0.18) -----

   Architecture :
     - Un fichier JSON par section : cheptel.json, medicaments.json,
       ordonnances.json, soins.json, settings.json
     - Un fichier manifest.json qui liste les versions de chaque section
     - Les photos d'ordonnances sont dans un sous-dossier photos/
       (un fichier .jpg par photo, nommé du photoId de l'ordonnance)

   À la synchronisation :
     1. On télécharge le manifest distant
     2. Pour chaque section, on compare versions locale vs distante :
        - locale > distante → upload de cette section
        - locale < distante → download (ou conflit si dirty local)
        - identique → rien
     3. Pour les photos : on compare les listes locale vs distante
        - photos locales nouvelles → upload
        - photos distantes nouvelles → ajoutées à state.photosManquantes
          (download à la demande quand l'utilisateur clique)
        - photos orphelines (sans ordonnance correspondante) → suppression

   Format des payloads JSON par section (en fichier séparé) :
     { "section": "cheptel", "version": N, "data": [...] }
   ============================================================ */

// Construit le payload pour une section donnée (sans les photos en base64
// pour ordonnances — celles-ci vont dans des fichiers séparés)
function buildSectionPayload(section) {
  let data;
  switch (section) {
    case 'cheptel': data = state.animaux; break;
    case 'medicaments': data = state.medicaments; break;
    case 'ordonnances':
      // On retire les dataUrl des photos pour alléger ce fichier.
      // Les photos sont stockées séparément dans photos/<id>.jpg
      data = state.ordonnances.map(o => ({
        ...o,
        photo: o.photo ? {
          width: o.photo.width,
          height: o.photo.height,
          sizeKb: o.photo.sizeKb,
          // dataUrl: omis intentionnellement
        } : null
      }));
      break;
    case 'soins': data = state.soins; break;
    case 'settings': data = state.settings; break;
    default: throw new Error('Section inconnue: ' + section);
  }
  return JSON.stringify({
    section: section,
    version: state.versions[section] || 0,
    savedAt: new Date().toISOString(),
    data: data
  }, null, 2);
}

// Applique localement le contenu d'un fichier de section téléchargé
function applySectionPayload(section, payload) {
  const obj = typeof payload === 'string' ? JSON.parse(payload) : payload;
  if (!obj || obj.section !== section) {
    throw new Error(`Payload invalide pour section ${section}`);
  }
  switch (section) {
    case 'cheptel': state.animaux = obj.data || []; break;
    case 'medicaments': state.medicaments = obj.data || []; break;
    case 'ordonnances':
      // Préserve les dataUrl des photos déjà présentes localement
      const oldPhotos = new Map();
      for (const o of (state.ordonnances || [])) {
        if (o.photo?.dataUrl) oldPhotos.set(o.id, o.photo.dataUrl);
      }
      state.ordonnances = (obj.data || []).map(o => {
        if (o.photo) {
          const existingDataUrl = oldPhotos.get(o.id);
          o.photo = {
            ...o.photo,
            dataUrl: existingDataUrl || null
          };
        }
        return o;
      });
      break;
    case 'soins': state.soins = obj.data || []; break;
    case 'settings':
      state.settings = { ...state.settings, ...(obj.data || {}) };
      break;
  }
  state.versions[section] = obj.version || 0;
}

// Construit le manifest local
function buildLocalManifest() {
  return {
    version: '5.0',
    updatedAt: new Date().toISOString(),
    files: {
      'cheptel.json': { version: state.versions.cheptel || 0 },
      'medicaments.json': { version: state.versions.medicaments || 0 },
      'ordonnances.json': { version: state.versions.ordonnances || 0 },
      'soins.json': { version: state.versions.soins || 0 },
      'settings.json': { version: state.versions.settings || 0 }
    }
  };
}

// Liste des photoIds dont l'ordonnance a une photo (présente OU absente localement)
function localPhotoIds() {
  const ids = [];
  for (const o of state.ordonnances || []) {
    if (o.photo) ids.push(o.id);
  }
  return ids;
}

// Synchronisation principale (multi-fichiers, delta, conflit)
// Mode 'auto' : déclenchée automatiquement (perte focus, démarrage), silencieuse si rien à faire
// Mode 'manual' : déclenchée par clic, toast systématique
async function synchronize(mode = 'manual') {
  const provider = getProvider();
  if (!provider) return;
  if (cloudState.status === 'syncing') return;
  if (cloudState.reconciling) return;

  cloudState.status = 'syncing';
  renderCloudBar();

  const summary = {
    uploaded: [],     // sections envoyées
    downloaded: [],   // sections reçues
    conflicts: [],    // sections en conflit
    photosUploaded: 0,
    photosDeleted: 0,
    photosToDownload: 0
  };

  try {
    // 1. Télécharger le manifest distant (peut être absent)
    let remoteManifest = null;
    try {
      const remoteRaw = await provider.loadFile('manifest.json');
      if (remoteRaw) remoteManifest = JSON.parse(remoteRaw);
    } catch (e) {
      // Si l'erreur est un 404 ou similaire, on traite comme s'il n'y avait pas de manifest
      console.warn('Manifest distant absent ou illisible :', e.message);
    }

    const localManifest = buildLocalManifest();

    // 2. Synchroniser chaque section
    const SECTIONS = ['cheptel', 'medicaments', 'ordonnances', 'soins', 'settings'];
    for (const section of SECTIONS) {
      const filename = section + '.json';
      const localVer = localManifest.files[filename].version;
      const remoteVer = remoteManifest?.files?.[filename]?.version || 0;

      if (localVer > remoteVer) {
        // Local plus récent → upload
        await provider.saveFile(filename, buildSectionPayload(section));
        summary.uploaded.push(section);
      } else if (remoteVer > localVer) {
        // Distant plus récent
        // Conflit possible si on a aussi modifié localement (rare mais possible si
        // une session précédente n'avait pas pu sync). Pour détecter ça, on compare
        // avec une version "snapshot" qu'on ne stocke pas pour l'instant.
        // Pour la v0.18, simplification : on télécharge le distant.
        const remotePayload = await provider.loadFile(filename);
        if (remotePayload) {
          applySectionPayload(section, remotePayload);
          summary.downloaded.push(section);
        }
      }
      // Sinon égal → rien à faire
    }

    // 3. Synchroniser les photos
    const localPhotos = new Set(localPhotoIds());
    const remotePhotosList = await provider.listPhotos();
    const remotePhotos = new Set(remotePhotosList.map(p => p.photoId));

    // Photos locales (avec dataUrl) à uploader si absentes du distant
    for (const o of state.ordonnances || []) {
      if (!o.photo?.dataUrl) continue;
      if (!remotePhotos.has(o.id)) {
        try {
          await provider.savePhoto(o.id, o.photo.dataUrl);
          summary.photosUploaded++;
        } catch (e) {
          console.warn('Échec upload photo ' + o.id, e);
        }
      }
    }

    // Photos distantes nouvelles : on les ajoute à photosManquantes pour
    // téléchargement à la demande (mode économe)
    state.photosManquantes = [];
    for (const o of state.ordonnances || []) {
      if (o.photo && !o.photo.dataUrl && remotePhotos.has(o.id)) {
        state.photosManquantes.push(o.id);
      }
    }
    summary.photosToDownload = state.photosManquantes.length;

    // Photos orphelines distantes (plus d'ordonnance correspondante) → suppression
    for (const remotePhoto of remotePhotosList) {
      if (!localPhotos.has(remotePhoto.photoId)) {
        try {
          await provider.deletePhoto(remotePhoto.photoId);
          summary.photosDeleted++;
        } catch (e) {
          console.warn('Échec suppression photo orpheline', e);
        }
      }
    }

    // 4. Mise à jour du manifest distant si on a uploadé quelque chose
    if (summary.uploaded.length > 0 || summary.photosUploaded > 0 || summary.photosDeleted > 0) {
      const newManifest = buildLocalManifest();
      await provider.saveFile('manifest.json', JSON.stringify(newManifest, null, 2));
    }

    cloudState.lastSync = new Date().toISOString();
    cloudState.status = 'connected';
    cloudState.errorMessage = null;
    cloudState.dirty = false;
    saveCloudConfig();
    persist(); // pour persister photosManquantes
    renderCloudBar();

    // Affichage du résumé
    const isQuiet = summary.uploaded.length === 0 && summary.downloaded.length === 0
                    && summary.photosUploaded === 0;
    if (mode === 'manual' || (!isQuiet && mode === 'auto')) {
      const parts = [];
      if (summary.uploaded.length) parts.push(`↑ ${summary.uploaded.join(', ')}`);
      if (summary.downloaded.length) parts.push(`↓ ${summary.downloaded.join(', ')}`);
      if (summary.photosUploaded) parts.push(`↑ ${summary.photosUploaded} photo${summary.photosUploaded > 1 ? 's' : ''}`);
      if (summary.photosToDownload) parts.push(`📥 ${summary.photosToDownload} photo${summary.photosToDownload > 1 ? 's' : ''} disponibles`);
      if (summary.photosDeleted) parts.push(`🗑 ${summary.photosDeleted} photo${summary.photosDeleted > 1 ? 's' : ''} obsolète${summary.photosDeleted > 1 ? 's' : ''}`);
      const msg = parts.length === 0 ? 'Tout est à jour' : parts.join(' · ');
      toast(msg, 'success');
    }

    return summary;
  } catch (e) {
    handleCloudError(e, 'Erreur de synchronisation');
    return null;
  }
}

// Téléchargement d'une photo à la demande (utilisateur clique sur "📥 Télécharger")
async function downloadPhoto(photoId) {
  const provider = getProvider();
  if (!provider) {
    toast('Pas de cloud configuré', 'error');
    return null;
  }
  try {
    const dataUrl = await provider.loadPhoto(photoId);
    if (!dataUrl) {
      toast('Photo introuvable sur le cloud', 'error');
      return null;
    }
    // Met à jour l'ordonnance correspondante
    const ord = state.ordonnances.find(o => o.id === photoId);
    if (ord && ord.photo) {
      ord.photo.dataUrl = dataUrl;
    }
    state.photosManquantes = state.photosManquantes.filter(id => id !== photoId);
    persist();
    return dataUrl;
  } catch (e) {
    handleCloudError(e, 'Téléchargement photo échoué');
    return null;
  }
}

// Wrapper de compatibilité ascendante : ancien syncToCloud appelle synchronize
async function syncToCloud(silent = false) {
  return await synchronize(silent ? 'auto' : 'manual');
}

function buildBackupPayload() {
  // Utilisé pour exportJSON et l'ancien sendBeacon (un seul fichier monolithique)
  return JSON.stringify({
    version: 5,
    exportedAt: new Date().toISOString(),
    animaux: state.animaux,
    medicaments: state.medicaments,
    ordonnances: state.ordonnances,
    soins: state.soins,
    settings: state.settings
  }, null, 2);
}

function todayBackupName() {
  const d = new Date();
  const yyyy = d.getFullYear();
  const mm = String(d.getMonth() + 1).padStart(2, '0');
  const dd = String(d.getDate()).padStart(2, '0');
  return `carnet-${yyyy}-${mm}-${dd}.json`;
}

function monthlyBackupName() {
  const d = new Date();
  const yyyy = d.getFullYear();
  const mm = String(d.getMonth() + 1).padStart(2, '0');
  return `carnet-${yyyy}-${mm}-mensuel.json`;
}

// Détecte si une erreur Cloud signifie "il faut redemander un token interactif"
// et met l'état cloud en conséquence. Sinon, erreur classique.
function handleCloudError(e, prefix) {
  if (e.code === 'NEED_RECONNECT') {
    cloudState.status = 'needs_reconnect';
    cloudState.errorMessage = 'Session Google expirée';
    renderCloudBar();
    // Pas de toast d'erreur agressif : la barre cloud propose le bouton.
    return;
  }
  cloudState.status = 'error';
  cloudState.errorMessage = e.message;
  renderCloudBar();
  toast(prefix + ' : ' + e.message, 'error');
}

// Reconnexion explicite : DOIT être appelée depuis un handler de clic
// utilisateur direct, sinon le navigateur bloque la popup OAuth.
async function reconnectCloud() {
  const provider = getProvider();
  if (!provider) return;
  try {
    // Mode interactif demandé : popup directe, déclenchée depuis un clic
    await provider._ensureToken(true);
    cloudState.status = 'connected';
    cloudState.errorMessage = null;
    renderCloudBar();
    toast('Reconnecté à ' + provider.name, 'success');
    // Si on avait des modifs en attente, on les pousse maintenant
    if (cloudState.dirty) {
      await syncToCloud(false);
    }
  } catch (e) {
    cloudState.status = 'needs_reconnect';
    cloudState.errorMessage = 'Reconnexion annulée';
    renderCloudBar();
    toast('Reconnexion annulée', 'error');
  }
}

async function rotateBackups(provider, files) {
  // Quotidiens : carnet-YYYY-MM-DD.json
  const daily = files.filter(f => /^carnet-\d{4}-\d{2}-\d{2}\.json$/.test(f.name))
                     .sort((a, b) => b.name.localeCompare(a.name));
  // Mensuels : carnet-YYYY-MM-mensuel.json
  const monthly = files.filter(f => /^carnet-\d{4}-\d{2}-mensuel\.json$/.test(f.name))
                       .sort((a, b) => b.name.localeCompare(a.name));

  // Garder 30 quotidiens + 12 mensuels
  const toDelete = [...daily.slice(30), ...monthly.slice(12)];
  for (const f of toDelete) {
    try { await provider.delete(f.id); } catch (e) { /* tolérant */ }
  }
}

// Sauvegarde différée (debounce ~30s) déclenchée à chaque modification
function scheduleAutoSave() {
  if (!getProvider() || cloudState.status === 'disconnected') return;
  // SÉCURITÉ : pendant la réconciliation post-connexion, l'utilisateur n'a pas
  // encore choisi entre garder le local ou restaurer le cloud. On ne planifie
  // AUCUNE sauvegarde tant qu'il n'a pas tranché.
  if (cloudState.reconciling) return;
  cloudState.dirty = true; // marque qu'il y a des modifs non sauvegardées
  renderCloudBar(); // affiche "modifs en attente"
  if (cloudState.pendingSaveTimer) clearTimeout(cloudState.pendingSaveTimer);
  cloudState.pendingSaveTimer = setTimeout(() => {
    cloudState.pendingSaveTimer = null;
    syncToCloud(false);
  }, 30000);
}

/* ----- Sauvegarde de fermeture ----- */
// Deux mécanismes complémentaires :
//  1. visibilitychange : déclenché quand l'onglet passe en arrière-plan
//     ou que l'app passe en arrière-plan sur mobile. La page est encore vivante,
//     un fetch normal aboutit. C'est le cas le plus fréquent en pratique.
//  2. pagehide / beforeunload : la page est en train de se fermer pour de bon.
//     Les fetch normaux peuvent être annulés. On utilise sendBeacon en dernier
//     recours, qui est l'API conçue pour ce cas précis.

// Sauvegarde déclenchée quand la page perd le focus / se ferme.
// Utilise fetch avec keepalive:true qui est l'API moderne et fiable pour ça :
// - Survit à la fermeture de la page (le navigateur garantit que la requête part)
// - Supporte les headers custom (Bearer token, multipart)
// - Limite à 64 ko par requête (largement suffisant pour notre JSON)
//
// On contourne aussi un point subtil : flushCloudSync est async, mais les
// event handlers visibilitychange ne peuvent pas attendre. La solution :
// fire-and-forget avec keepalive sur un upload simple.

function flushCloudSyncSync() {
  if (!getProvider() || !cloudState.dirty) return;
  if (cloudState.reconciling) return;
  const provider = getProvider();
  if (provider.id !== 'google-drive' || !provider.accessToken) return;
  if (!cloudState.folderId) return;

  // Annule le timer en cours si présent
  if (cloudState.pendingSaveTimer) {
    clearTimeout(cloudState.pendingSaveTimer);
    cloudState.pendingSaveTimer = null;
  }

  try {
    const payload = buildBackupPayload();
    const filename = todayBackupName();

    // Marquer comme "non dirty" optimistiquement pour éviter les doubles flushes
    cloudState.dirty = false;

    // On a besoin de connaître l'ID du fichier du jour pour faire un PATCH propre.
    // Comme on ne peut pas faire un GET puis PATCH ici (deux requêtes et timing serré),
    // on lance une logique en deux requêtes asynchrones avec keepalive.
    // La 1ère cherche le fichier, la 2nde le met à jour ou le crée.

    // Pour simplifier et garantir la livraison : on poste directement un nouveau fichier
    // avec son nom comme métadonnée. Si le fichier du jour existe déjà, le suivant
    // sera nettoyé par la prochaine rotation. C'est tolérant au pire cas.
    const boundary = '-------flush' + Math.random().toString(36).slice(2);
    const delim = '\r\n--' + boundary + '\r\n';
    const closeDelim = '\r\n--' + boundary + '--';
    const metadata = { name: filename, parents: [cloudState.folderId] };
    const body =
      delim +
      'Content-Type: application/json; charset=UTF-8\r\n\r\n' +
      JSON.stringify(metadata) +
      delim +
      'Content-Type: application/json\r\n\r\n' +
      payload +
      closeDelim;

    // fetch avec keepalive : la requête est garantie d'être envoyée même si la page
    // se ferme dans la milliseconde qui suit. Pas besoin d'attendre la promesse.
    fetch('https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart', {
      method: 'POST',
      headers: {
        'Authorization': 'Bearer ' + provider.accessToken,
        'Content-Type': 'multipart/related; boundary=' + boundary
      },
      body: body,
      keepalive: true
    }).catch(err => {
      // Erreur silencieuse : la page peut être en train de se fermer
      console.warn('flush keepalive échoué:', err);
      // Si on échoue, on remarque dirty pour réessayer au prochain cycle
      cloudState.dirty = true;
    });
  } catch (e) {
    cloudState.dirty = true; // restaure l'état pour réessayer
    console.warn('flush sync échoué:', e);
  }
}

// Sauvegarde différée mais qui tente toujours via fetch normal (avec syncToCloud
// qui fait PATCH propre + rotation). Utilisée pour les cas non urgents.
async function flushCloudSync() {
  if (!getProvider() || !cloudState.dirty) return;
  if (cloudState.reconciling) return;
  if (cloudState.pendingSaveTimer) {
    clearTimeout(cloudState.pendingSaveTimer);
    cloudState.pendingSaveTimer = null;
  }
  await syncToCloud(true);
}

// Quand l'onglet devient invisible : flush immédiat avec keepalive.
// Sur mobile, c'est le moment où il faut absolument sauvegarder, parce que
// le navigateur peut décider de tuer l'onglet à tout moment ensuite.
document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'hidden' && cloudState.dirty) {
    flushCloudSyncSync(); // version keepalive, fire-and-forget
  }
});

// pagehide : équivalent fiable de beforeunload sur tous navigateurs (incluant iOS Safari
// qui ignore beforeunload). Déclenché juste avant fermeture définitive de la page.
window.addEventListener('pagehide', () => {
  if (cloudState.dirty) flushCloudSyncSync();
});

// beforeunload : conservé en doublon pour les navigateurs desktop.
// Ne fait pas de fenêtre "Voulez-vous vraiment quitter ?".
window.addEventListener('beforeunload', () => {
  if (cloudState.dirty) flushCloudSyncSync();
});

/* ----- Rendu de la barre de statut cloud ----- */

function renderCloudBar() {
  const bar = document.getElementById('cloud-bar');
  const icon = document.getElementById('cloud-icon');
  const label = document.getElementById('cloud-label');
  const actions = bar.querySelector('.actions');

  bar.classList.remove('disconnected', 'connected', 'error');
  actions.innerHTML = '';

  const provider = getProvider();

  if (!provider) {
    bar.classList.add('disconnected');
    icon.textContent = '!';
    label.innerHTML = '<strong>Pas de cloud</strong>';
    const cfgBtn = document.createElement('button');
    cfgBtn.textContent = 'Configurer';
    cfgBtn.addEventListener('click', openConfigModal);
    actions.appendChild(cfgBtn);
    return;
  }

  if (cloudState.status === 'syncing') {
    bar.classList.add('connected');
    icon.textContent = '↻';
    label.innerHTML = '<span class="syncing"></span><strong>Sauvegarde…</strong>';
    return;
  }

  if (cloudState.status === 'needs_reconnect') {
    bar.classList.add('error');
    icon.textContent = '!';
    const dirtyMark = cloudState.dirty ? ' · ⚠ modifs non sauv.' : '';
    label.innerHTML = `<strong>Session expirée</strong>${dirtyMark}`;
    const reconnectBtn = document.createElement('button');
    reconnectBtn.textContent = '↻ Reconnecter';
    reconnectBtn.className = 'primary';
    reconnectBtn.addEventListener('click', reconnectCloud);
    actions.appendChild(reconnectBtn);
    return;
  }

  if (cloudState.status === 'error') {
    bar.classList.add('error');
    icon.textContent = '✕';
    label.innerHTML = `<strong>Erreur</strong> — ${cloudState.errorMessage || 'voir détail'}`;
    const retry = document.createElement('button');
    retry.textContent = 'Réessayer';
    retry.addEventListener('click', () => syncToCloud(false));
    actions.appendChild(retry);
    return;
  }

  // Connected
  bar.classList.add('connected');
  icon.textContent = cloudState.dirty ? '⋯' : '✓';
  const since = cloudState.lastSync ? formatRelative(cloudState.lastSync) : 'jamais';
  if (cloudState.dirty) {
    label.innerHTML = `<strong>Modifs locales</strong>`;
  } else {
    label.innerHTML = `<strong>Synchro</strong> ${since}`;
  }

  // Bouton unique "Synchroniser" : envoie ce qui a changé localement et
  // récupère ce qui a changé sur le cloud, en mode delta (multi-fichiers).
  const syncBtn = document.createElement('button');
  syncBtn.textContent = '⟳ Sync';
  syncBtn.title = 'Synchroniser maintenant (envoie les modifs locales et récupère les modifs distantes)';
  syncBtn.addEventListener('click', () => synchronize('manual'));
  actions.appendChild(syncBtn);

  const cfgBtn = document.createElement('button');
  cfgBtn.textContent = '⚙';
  cfgBtn.title = 'Réglages cloud';
  cfgBtn.addEventListener('click', openConfigModal);
  actions.appendChild(cfgBtn);
}

function formatRelative(iso) {
  const d = new Date(iso);
  const diff = Date.now() - d.getTime();
  const sec = Math.floor(diff / 1000);
  if (sec < 60) return 'à l\'instant';
  const min = Math.floor(sec / 60);
  if (min < 60) return `il y a ${min} min`;
  const h = Math.floor(min / 60);
  if (h < 24) return `il y a ${h} h`;
  const days = Math.floor(h / 24);
  if (days === 1) return 'hier';
  if (days < 30) return `il y a ${days} j`;
  return 'le ' + d.toLocaleDateString('fr-FR');
}

/* ----- Modal de configuration ----- */

function openConfigModal() {
  const body = document.getElementById('config-body');
  const provider = getProvider();
  const driveAvailable = GoogleDriveProvider.isAvailable();

  let html = '<p>Tes données restent privées : chaque éleveur connecte <strong>son propre</strong> compte cloud. Aucun serveur centralisé.</p>';

  // Carte Google Drive
  html += `<div class="provider-card${driveAvailable ? '' : ' unavailable'}">`;
  html += '<div class="head">';
  html += '<div><div class="name">Google Drive</div>';
  html += '<div class="desc">Sauvegarde dans un dossier dédié de ton Drive personnel</div></div>';
  if (provider?.id === 'google-drive') {
    html += '<button id="cloud-disconnect" class="ghost danger">Déconnecter</button>';
  } else if (driveAvailable) {
    html += '<button id="cloud-connect-drive" class="primary">Connecter</button>';
  } else {
    html += '<span class="badge race">Non configuré</span>';
  }
  html += '</div>';
  if (!driveAvailable) {
    html += '<div class="info">Cette app n\'a pas encore de Client ID Google configuré. Pour activer Drive, suis les étapes dans les commentaires en haut du fichier source (variable <code>GOOGLE_CLIENT_ID</code>).</div>';
  } else if (provider?.id === 'google-drive') {
    html += `<div class="info">✓ Connecté. Sauvegardes dans le dossier <strong>${CLOUD_FOLDER_NAME}</strong> de ton Drive. Rotation automatique : 30 jours quotidiens + 12 mensuels.</div>`;
  }
  html += '</div>';

  // Cartes futures (placeholder)
  html += `<div class="provider-card unavailable">
    <div class="head">
      <div><div class="name">Dropbox</div><div class="desc">À venir dans une prochaine version</div></div>
      <span class="badge race">Bientôt</span>
    </div>
  </div>`;
  html += `<div class="provider-card unavailable">
    <div class="head">
      <div><div class="name">OneDrive</div><div class="desc">À venir dans une prochaine version</div></div>
      <span class="badge race">Bientôt</span>
    </div>
  </div>`;

  html += '<div class="info" style="margin-top:18px"><strong>Note :</strong> la sauvegarde manuelle vers fichier (bouton <em>Sauvegarder</em> de la barre d\'outils) reste toujours disponible en complément.</div>';

  body.innerHTML = html;

  // Liaisons
  const connectBtn = document.getElementById('cloud-connect-drive');
  if (connectBtn) connectBtn.addEventListener('click', connectGoogleDrive);
  const disconnectBtn = document.getElementById('cloud-disconnect');
  if (disconnectBtn) disconnectBtn.addEventListener('click', disconnectCloud);

  document.getElementById('config-modal-bg').classList.add('show');
}

async function connectGoogleDrive() {
  try {
    toast('Ouverture de la fenêtre Google…');
    await GoogleDriveProvider.connect();
    cloudState.provider = 'google-drive';
    cloudState.status = 'connected';
    saveCloudConfig();
    document.getElementById('config-modal-bg').classList.remove('show');
    toast('Google Drive connecté', 'success');

    // SÉCURITÉ : avant toute sauvegarde, on vérifie s'il existe déjà des
    // sauvegardes sur le Drive. Si oui, on ne touche à RIEN tant que
    // l'utilisateur n'a pas choisi (restaurer / garder local).
    await handleConnectionSync();
  } catch (e) {
    toast('Connexion impossible : ' + e.message, 'error');
    // En cas d'erreur, on déconnecte pour ne pas laisser un état incohérent
    cloudState.provider = null;
    cloudState.status = 'disconnected';
    saveCloudConfig();
    renderCloudBar();
  }
}

// Logique de réconciliation à la première connexion
async function handleConnectionSync() {
  const provider = getProvider();
  if (!provider) return;

  let existingBackups = [];
  try {
    existingBackups = await provider.list();
  } catch (e) {
    handleCloudError(e, 'Impossible de lire le dossier Drive');
    return;
  }

  const hasLocal = state.animaux.length > 0;
  const hasRemote = existingBackups.length > 0;

  // Cas 1 : Drive vide + local vide → première utilisation, rien à faire
  if (!hasRemote && !hasLocal) {
    cloudState.lastSync = new Date().toISOString();
    saveCloudConfig();
    renderCloudBar();
    toast('Drive prêt, importe ton CSV pour commencer');
    return;
  }

  // Cas 2 : Drive vide + local non vide → premier upload légitime
  if (!hasRemote && hasLocal) {
    renderCloudBar();
    await syncToCloud(false);
    return;
  }

  // Cas 3 : Drive non vide + local vide → DANGER, surtout pas écraser
  // On ouvre la modal de restauration et on bloque toute sauvegarde tant que
  // l'utilisateur n'a pas choisi.
  if (hasRemote && !hasLocal) {
    cloudState.status = 'connected';
    renderCloudBar();
    await openRestoreOnConnectModal(existingBackups, false);
    return;
  }

  // Cas 4 : Drive non vide + local non vide → conflit, demander à l'utilisateur
  if (hasRemote && hasLocal) {
    cloudState.status = 'connected';
    renderCloudBar();
    await openRestoreOnConnectModal(existingBackups, true);
    return;
  }
}

// Modal de réconciliation : présente le choix "garder le local" vs "restaurer
// une sauvegarde du cloud". Tant que l'utilisateur n'a pas choisi, AUCUNE
// sauvegarde automatique ne part vers le cloud (verrouillé par
// cloudState.reconciling).
async function openRestoreOnConnectModal(backups, hasLocalData) {
  const body = document.getElementById('backups-body');
  document.getElementById('backups-modal-bg').classList.add('show');

  // Verrouille toute sauvegarde tant que l'utilisateur n'a pas tranché
  cloudState.reconciling = true;
  cloudState.dirty = false;
  if (cloudState.pendingSaveTimer) {
    clearTimeout(cloudState.pendingSaveTimer);
    cloudState.pendingSaveTimer = null;
  }

  const modalHead = document.querySelector('#backups-modal-bg .modal-head h2');
  modalHead.textContent = 'Sauvegardes trouvées sur Drive';

  let html = '';
  if (hasLocalData) {
    html += `<p>Ce navigateur contient déjà <strong>${state.animaux.length} animaux</strong>.<br>
      Ton Drive contient ${backups.length} sauvegarde(s) existante(s).</p>
      <div class="info" style="background:rgba(184,131,10,0.1);border-left-color:var(--jaune)">
        <strong>⚠ Choix important :</strong> que veux-tu garder comme version de référence ?
      </div>`;
  } else {
    html += `<p>Ton Drive contient ${backups.length} sauvegarde(s) existante(s).<br>
      Cet appareil ne contient aucune donnée locale.</p>
      <div class="info" style="background:rgba(184,131,10,0.1);border-left-color:var(--jaune)">
        <strong>Sécurité :</strong> aucune sauvegarde automatique ne partira tant que tu n'auras pas choisi. Sélectionne une sauvegarde à restaurer.
      </div>`;
  }

  // Boutons d'action haut niveau
  html += '<div style="display:flex;gap:8px;flex-wrap:wrap;margin:14px 0">';
  if (hasLocalData) {
    html += '<button id="keep-local" class="primary">Garder mes données locales (et écraser le Drive)</button>';
  }
  html += '<button id="cancel-connect" class="ghost danger">Annuler la connexion</button>';
  html += '</div>';

  // Liste des sauvegardes restaurables
  html += '<h3 style="margin:18px 0 8px">Ou restaurer une sauvegarde existante :</h3>';
  html += '<ul class="backup-list">';
  for (const f of backups) {
    const isMonthly = f.name.includes('mensuel');
    const dateStr = new Date(f.modifiedTime).toLocaleString('fr-FR', {
      day: '2-digit', month: '2-digit', year: 'numeric',
      hour: '2-digit', minute: '2-digit'
    });
    const sizeKb = (f.size / 1024).toFixed(1);
    html += `<li class="backup-item" data-id="${f.id}" data-name="${f.name}">
      <div class="meta">
        <div class="name">${f.name}${isMonthly ? ' <span class="tag">Mensuel</span>' : ''}</div>
        <div class="date">Modifié ${dateStr}</div>
      </div>
      <div class="size">${sizeKb} ko</div>
    </li>`;
  }
  html += '</ul>';

  body.innerHTML = html;

  // Liaisons
  body.querySelectorAll('.backup-item').forEach(item => {
    item.addEventListener('click', async () => {
      if (!confirm(`Restaurer "${item.dataset.name}" ?`)) return;
      try {
        const text = await getProvider().load(item.dataset.id);
        const data = JSON.parse(text);
        if (!data.animaux || !Array.isArray(data.animaux)) {
          throw new Error('Format invalide');
        }
        state.animaux = data.animaux;
        state.medicaments = (data.medicaments && Array.isArray(data.medicaments)) ? data.medicaments : [];
        state.ordonnances = (data.ordonnances && Array.isArray(data.ordonnances)) ? data.ordonnances : [];
        state.soins = (data.soins && Array.isArray(data.soins)) ? data.soins : [];
        if (data.settings && typeof data.settings === 'object') {
          state.settings = { ...state.settings, ...data.settings };
        }
        persistLocalOnly(); // sauvegarde localStorage seulement, sans déclencher scheduleAutoSave
        render();
        document.getElementById('backups-modal-bg').classList.remove('show');
        toast(`${data.animaux.length} animaux restaurés`, 'success');
        // Réconciliation tranchée : déverrouille les sauvegardes
        cloudState.reconciling = false;
        cloudState.lastSync = new Date().toISOString();
        cloudState.dirty = false;
        saveCloudConfig();
        renderCloudBar();
      } catch (e) {
        toast('Erreur de restauration : ' + e.message, 'error');
      }
    });
  });

  const keepBtn = document.getElementById('keep-local');
  if (keepBtn) {
    keepBtn.addEventListener('click', async () => {
      if (!confirm('Confirmer ? Les sauvegardes existantes sur Drive seront remplacées par tes données locales.')) return;
      document.getElementById('backups-modal-bg').classList.remove('show');
      // Réconciliation tranchée : déverrouille
      cloudState.reconciling = false;
      await syncToCloud(false);
    });
  }

  document.getElementById('cancel-connect').addEventListener('click', () => {
    document.getElementById('backups-modal-bg').classList.remove('show');
    // Déconnecte le cloud pour revenir à l'état antérieur
    if (getProvider()) getProvider().disconnect();
    cloudState.provider = null;
    cloudState.status = 'disconnected';
    cloudState.lastSync = null;
    cloudState.dirty = false;
    cloudState.reconciling = false;
    saveCloudConfig();
    renderCloudBar();
    toast('Connexion annulée');
  });
}

// Variante de persist() qui n'envoie PAS la sauvegarde au cloud
// (utilisée lors de la restauration depuis le cloud, pour éviter une boucle)
function persistLocalOnly() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({
      version: 1,
      savedAt: new Date().toISOString(),
      animaux: state.animaux
    }));
  } catch (e) {
    toast('Erreur de sauvegarde locale : ' + e.message, 'error');
  }
}

function disconnectCloud() {
  if (!confirm('Déconnecter le cloud ? Les sauvegardes existantes restent sur ton Drive.')) return;
  const provider = getProvider();
  if (provider) provider.disconnect();
  cloudState.provider = null;
  cloudState.status = 'disconnected';
  cloudState.lastSync = null;
  saveCloudConfig();
  renderCloudBar();
  document.getElementById('config-modal-bg').classList.remove('show');
  toast('Cloud déconnecté');
}

/* ----- Modal de restauration ----- */

async function openBackupsModal() {
  const body = document.getElementById('backups-body');
  body.innerHTML = '<p>Chargement de la liste des sauvegardes…</p>';
  // Remet le titre par défaut (peut avoir été modifié par la modal de réconciliation)
  document.querySelector('#backups-modal-bg .modal-head h2').textContent = 'Restaurer depuis Drive';
  document.getElementById('backups-modal-bg').classList.add('show');

  const provider = getProvider();
  try {
    const files = await provider.list();
    if (files.length === 0) {
      body.innerHTML = '<p>Aucune sauvegarde disponible sur ton Drive pour le moment.</p>';
      return;
    }
    let html = '<p>Sélectionne une sauvegarde à restaurer. <strong>Tes données actuelles seront remplacées</strong>.</p><ul class="backup-list">';
    for (const f of files) {
      const isMonthly = f.name.includes('mensuel');
      const dateStr = new Date(f.modifiedTime).toLocaleString('fr-FR', {
        day: '2-digit', month: '2-digit', year: 'numeric',
        hour: '2-digit', minute: '2-digit'
      });
      const sizeKb = (f.size / 1024).toFixed(1);
      html += `<li class="backup-item" data-id="${f.id}" data-name="${f.name}">
        <div class="meta">
          <div class="name">${f.name}${isMonthly ? ' <span class="tag">Mensuel</span>' : ''}</div>
          <div class="date">Modifié ${dateStr}</div>
        </div>
        <div class="size">${sizeKb} ko</div>
      </li>`;
    }
    html += '</ul>';
    body.innerHTML = html;
    body.querySelectorAll('.backup-item').forEach(item => {
      item.addEventListener('click', () => restoreFromCloud(item.dataset.id, item.dataset.name));
    });
  } catch (e) {
    if (e.code === 'NEED_RECONNECT') {
      // Session Google expirée. On affiche un bouton de reconnexion DANS la
      // modal — son clic sera dans une chaîne d'événements utilisateur valide
      // donc le navigateur acceptera la popup OAuth.
      body.innerHTML = `
        <p>Ta session Google a expiré. Pour voir tes sauvegardes, reconnecte-toi.</p>
        <div style="display:flex;gap:8px;margin-top:14px">
          <button id="modal-reconnect" class="primary" style="background:var(--terre);color:var(--paper);border-color:var(--terre)">↻ Reconnecter à Google Drive</button>
          <button id="modal-cancel" class="ghost">Annuler</button>
        </div>`;
      document.getElementById('modal-reconnect').addEventListener('click', async () => {
        try {
          await getProvider()._ensureToken(true);
          cloudState.status = 'connected';
          renderCloudBar();
          // Recharge la liste après reconnexion
          await openBackupsModal();
        } catch (err) {
          body.innerHTML = `<p style="color:var(--rouge)">Reconnexion annulée : ${err.message}</p>`;
        }
      });
      document.getElementById('modal-cancel').addEventListener('click', () => {
        document.getElementById('backups-modal-bg').classList.remove('show');
      });
      // Et on met aussi la barre cloud en mode needs_reconnect
      cloudState.status = 'needs_reconnect';
      cloudState.errorMessage = 'Session Google expirée';
      renderCloudBar();
    } else {
      body.innerHTML = `<p style="color:var(--rouge)">Erreur de chargement : ${e.message}</p>`;
    }
  }
}

async function restoreFromCloud(fileId, filename) {
  if (!confirm(`Restaurer "${filename}" ? Les données actuelles seront remplacées.`)) return;
  try {
    const text = await getProvider().load(fileId);
    const data = JSON.parse(text);
    if (!data.animaux || !Array.isArray(data.animaux)) {
      throw new Error('Format invalide');
    }
    state.animaux = data.animaux;
    state.medicaments = (data.medicaments && Array.isArray(data.medicaments)) ? data.medicaments : [];
    state.ordonnances = (data.ordonnances && Array.isArray(data.ordonnances)) ? data.ordonnances : [];
    state.soins = (data.soins && Array.isArray(data.soins)) ? data.soins : [];
    if (data.settings && typeof data.settings === 'object') {
      state.settings = { ...state.settings, ...data.settings };
    }
    persistLocalOnly(); // évite une re-sync immédiate vers le cloud
    render();
    document.getElementById('backups-modal-bg').classList.remove('show');
    toast(`${data.animaux.length} animaux restaurés`, 'success');
    // Marque comme synchronisé : le contenu vient du cloud lui-même
    cloudState.lastSync = new Date().toISOString();
    cloudState.dirty = false;
    saveCloudConfig();
    renderCloudBar();
  } catch (e) {
    if (e.code === 'NEED_RECONNECT') {
      handleCloudError(e, '');
      toast('Session Google expirée — reconnecte-toi via la barre cloud', 'error');
    } else {
      toast('Erreur de restauration : ' + e.message, 'error');
    }
  }
}

/* ============================================================
   ÉVÉNEMENTS
   ============================================================ */

document.getElementById('search').addEventListener('input', (e) => {
  state.filtres.recherche = e.target.value;
