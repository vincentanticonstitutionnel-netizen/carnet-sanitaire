<!DOCTYPE html>
<!--
  Carnet sanitaire — v0.18
  Outil de suivi de cheptel et carnet sanitaire pour éleveurs bovins.
  Données stockées en local + sauvegarde optionnelle Google Drive.

  Historique :
    v0.18 — Refonte du système de sauvegarde Drive en multi-fichiers (cheptel.json,
            medicaments.json, ordonnances.json, soins.json, settings.json + manifest.json).
            Photos d'ordonnances dans un sous-dossier photos/ (un fichier par photo).
            Synchronisation delta : seules les sections modifiées sont uploadées.
            Bouton unique ⟳ Sync remplace les anciens "Sauvegarder" / "Restaurer".
            Photos téléchargées à la demande (économie data sur réseau faible).
            Migration automatique depuis l'ancien format monolithique au démarrage.
            Économie réelle attendue : facteur 100 sur la bande passante.
    v0.17 — Sprint 2 (2/4) : ordonnances vétérinaires.
            Saisie complète (date, vétérinaire, n°, photo via caméra ou fichier),
            prescriptions multiples par ordonnance, compression photos.
    v0.16 — Forçage manuel du statut bio depuis la fiche animal.
            Migration du menu ⋮ dans le header.
    v0.15 — Correction règle bio : les animaux nés en exploitation bio
            sont bio dès la naissance, sans période de conversion.
    v0.14 — Correction du calcul du statut bio : application stricte du
            règlement CE 2018/848 annexe II (12 mois ET 75% de vie en bio).
    v0.13 — Barre de sauvegarde déplacée dans le header (toujours visible).
            Statut bio par animal : pastille colorée.
    v0.12 — Réglages d'exploitation : mode Agriculture biologique (AB).
    v0.11 — Fix sauvegarde sur perte de focus : passage à fetch keepalive.
    v0.10 — Sprint 2 (1/4) : navigation Cheptel/Sanitaire avec onglets,
            bibliothèque médicaments.
    v0.9 — Tri intelligent des races (cheptel + croisée en haut),
           sélection père dans la liste des mâles ≥ 8 mois,
           édition du nom et suppression d'animal depuis la fiche détail.
    v0.8 — Ajout manuel d'animaux + toolbar épurée.
    v0.7 — Token persisté en localStorage (contournement COOP GitHub Pages).
    v0.6 — Reconnexion silencieuse au démarrage + cache token sessionStorage.
    v0.5 — Fix popup OAuth bloquée par le navigateur.
    v0.4 — Robustesse OAuth.
    v0.3 — Réconciliation à la connexion.
    v0.2 — Sauvegarde sur perte de focus + indicateur "modifs en attente".
    v0.1 — Sauvegarde Google Drive (debounce 30s).
    v0.0 — Sprint 1 : import CSV Synel, liste, recherche, sauvegarde locale.
-->
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#3d2817">
<title>Carnet sanitaire 0.18</title>
<style>
  /* ============================================================
     Carnet sanitaire — prototype Sprint 1
     Direction : utilitaire propre, palette terre/papier
     ============================================================ */
  :root {
    --paper: #f5f1e8;
    --paper-2: #ebe4d3;
    --ink: #2a1f12;
    --ink-2: #5a4a35;
    --ink-3: #8a7a60;
    --terre: #6b3e1f;
    --terre-2: #8a5a3a;
    --vert: #4a6b1f;
    --vert-2: #6b8a3a;
    --rouge: #8b2a2a;
    --jaune: #b8830a;
    --bleu: #2a5a7a;
    --line: #c8bfa8;
    --line-2: #d8d0bc;
    --shadow: 0 1px 0 rgba(58, 40, 23, 0.08);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background: var(--paper);
    color: var(--ink);
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, 'Book Antiqua', Georgia, serif;
    font-size: 16px;
    line-height: 1.45;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  body {
    padding-bottom: env(safe-area-inset-bottom);
  }

  /* Header */
  header {
    background: var(--ink);
    color: var(--paper);
    padding: 12px 18px;
    padding-top: calc(12px + env(safe-area-inset-top));
    border-bottom: 3px double var(--terre);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .header-row {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .header-title { flex: 0 0 auto; min-width: 0; }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 0 1 auto;
    min-width: 0;
  }
  .header-menu-btn {
    background: rgba(255, 255, 255, 0.08);
    color: var(--paper);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 4px;
    width: 36px;
    height: 32px;
    font-size: 18px;
    line-height: 1;
    padding: 0;
    cursor: pointer;
    box-shadow: none;
    flex-shrink: 0;
  }
  .header-menu-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.25);
  }
  header h1 {
    font-size: 17px;
    font-weight: 500;
    letter-spacing: 0.02em;
    font-variant: small-caps;
  }
  header .sub {
    font-size: 11px;
    color: var(--paper-2);
    opacity: 0.75;
    margin-top: 2px;
  }

  /* Main */
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 16px;
  }

  /* Toolbar */
  .toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-bottom: 16px;
    padding: 12px;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 4px;
  }
  .toolbar input[type="search"] {
    flex: 1;
    min-width: 180px;
    padding: 10px 12px;
    border: 1px solid var(--line);
    background: var(--paper);
    color: var(--ink);
    font-family: inherit;
    font-size: 16px;
    border-radius: 3px;
  }
  .toolbar input[type="search"]:focus {
    outline: 2px solid var(--terre);
    outline-offset: -1px;
  }

  .filters {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  /* Buttons */
  button, label.btn {
    font-family: inherit;
    font-size: 14px;
    padding: 9px 14px;
    border: 1px solid var(--line);
    background: var(--paper);
    color: var(--ink);
    border-radius: 3px;
    cursor: pointer;
    transition: background 0.12s, border-color 0.12s;
    box-shadow: var(--shadow);
    user-select: none;
    white-space: nowrap;
  }
  button:hover, label.btn:hover { background: var(--paper-2); border-color: var(--ink-3); }
  button:active { transform: translateY(1px); }
  button.primary {
    background: var(--terre);
    color: var(--paper);
    border-color: var(--terre);
  }
  button.primary:hover { background: var(--terre-2); border-color: var(--terre-2); }
  button.ghost {
    background: transparent;
    border-color: var(--line);
  }
  button.toggle[aria-pressed="true"] {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  button.danger { color: var(--rouge); }

  /* Stats */
  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 8px;
    margin-bottom: 16px;
  }
  .stat {
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 10px 12px;
  }
  .stat .v {
    font-size: 24px;
    font-weight: 500;
    color: var(--ink);
    font-feature-settings: 'tnum';
  }
  .stat .l {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    margin-top: 2px;
  }

  /* Table desktop */
  .table-wrap {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  thead th {
    background: var(--paper-2);
    text-align: left;
    padding: 10px 12px;
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink-2);
    border-bottom: 2px solid var(--line);
    cursor: pointer;
    user-select: none;
    position: sticky;
    top: 0;
  }
  thead th:hover { background: var(--line-2); }
  thead th.sort-asc::after { content: ' ▲'; opacity: 0.5; }
  thead th.sort-desc::after { content: ' ▼'; opacity: 0.5; }
  tbody tr {
    border-bottom: 1px solid var(--line-2);
    cursor: pointer;
  }
  tbody tr:hover { background: var(--paper-2); }
  tbody tr.sortie { color: var(--ink-3); font-style: italic; }
  tbody td {
    padding: 10px 12px;
    font-feature-settings: 'tnum';
  }
  td.num-trav { font-weight: 500; color: var(--terre); }
  td.nom { font-weight: 500; }
  .badge {
    display: inline-block;
    padding: 1px 7px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: 1px solid;
  }
  .badge.f { background: rgba(184, 131, 10, 0.1); color: var(--jaune); border-color: rgba(184, 131, 10, 0.3); }
  .badge.m { background: rgba(42, 90, 122, 0.1); color: var(--bleu); border-color: rgba(42, 90, 122, 0.3); }
  .badge.race { background: var(--paper-2); color: var(--ink-2); border-color: var(--line); }

  /* Pastille de statut bio */
  .bio-dot {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    margin-right: 6px;
    vertical-align: 0;
    border: 1px solid rgba(0, 0, 0, 0.15);
    flex-shrink: 0;
  }
  .bio-dot[data-status="conversion"] {
    box-shadow: 0 0 0 2px rgba(212, 154, 20, 0.15);
  }
  .bio-dot[data-status="bio"] {
    box-shadow: 0 0 0 2px rgba(74, 138, 31, 0.15);
  }

  /* Contrôles de mode bio dans la fiche détail */
  .bio-mode-group {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 4px;
  }
  .bio-mode-option {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: var(--paper);
    cursor: pointer;
    font-size: 12px;
    transition: background 0.12s, border-color 0.12s;
  }
  .bio-mode-option:hover { background: var(--paper-2); border-color: var(--ink-3); }
  .bio-mode-option.active {
    background: var(--paper-2);
    border-color: var(--terre);
    color: var(--ink);
  }
  .bio-mode-option input { margin: 0; cursor: pointer; }

  /* Empty state */
  .empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--ink-3);
  }
  .empty h2 {
    font-size: 22px;
    color: var(--ink);
    margin-bottom: 8px;
    font-weight: 500;
  }
  .empty p { margin-bottom: 20px; max-width: 460px; margin-left: auto; margin-right: auto; }
  .empty .actions { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }

  /* Mobile cards */
  .cards { display: none; flex-direction: column; gap: 8px; }
  .card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 12px 14px;
    box-shadow: var(--shadow);
    cursor: pointer;
  }
  .card.sortie { opacity: 0.65; }
  .card-head { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
  .card-head .nom { font-size: 17px; font-weight: 500; }
  .card-head .ntrav { font-size: 13px; color: var(--terre); font-weight: 500; }
  .card-meta { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 6px; font-size: 13px; color: var(--ink-2); }
  .card-meta .sep { color: var(--line); }
  .card-num { font-size: 11px; color: var(--ink-3); margin-top: 4px; font-feature-settings: 'tnum'; }

  /* Modal détail */
  .modal-bg {
    position: fixed; inset: 0;
    background: rgba(42, 31, 18, 0.5);
    z-index: 100;
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding: 20px;
    overflow-y: auto;
  }
  .modal-bg.show { display: flex; }
  .modal {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 4px;
    max-width: 560px;
    width: 100%;
    margin: 20px 0;
    box-shadow: 0 10px 40px rgba(42, 31, 18, 0.3);
  }
  .modal-head {
    padding: 18px 20px;
    border-bottom: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .modal-head h2 { font-size: 22px; font-weight: 500; }
  .modal-head .close {
    background: transparent;
    border: none;
    font-size: 24px;
    color: var(--ink-2);
    cursor: pointer;
    padding: 4px 10px;
    box-shadow: none;
  }
  .modal-body { padding: 18px 20px; }
  .field {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 12px;
    padding: 8px 0;
    border-bottom: 1px solid var(--line-2);
    font-size: 14px;
  }
  .field:last-child { border-bottom: none; }
  .field .l {
    color: var(--ink-3);
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.04em;
    padding-top: 2px;
  }
  .field .v { font-feature-settings: 'tnum'; }
  .section-title {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--terre);
    margin: 16px 0 6px;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--terre);
  }
  .section-title:first-child { margin-top: 0; }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--ink);
    color: var(--paper);
    padding: 12px 20px;
    border-radius: 3px;
    font-size: 14px;
    box-shadow: 0 4px 16px rgba(42, 31, 18, 0.3);
    z-index: 200;
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    pointer-events: none;
    max-width: calc(100vw - 40px);
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(-4px); }
  .toast.error { background: var(--rouge); }
  .toast.success { background: var(--vert); }

  /* Cloud status bar (intégrée au header sombre) */
  .cloud-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 4px;
    font-size: 12px;
    color: var(--paper-2);
    max-width: 360px;
    min-width: 0;
    flex: 0 1 auto;
  }
  .cloud-bar.disconnected {
    background: rgba(184, 131, 10, 0.18);
    border-color: rgba(184, 131, 10, 0.45);
  }
  .cloud-bar.connected {
    background: rgba(107, 138, 58, 0.18);
    border-color: rgba(107, 138, 58, 0.45);
  }
  .cloud-bar.error {
    background: rgba(180, 70, 70, 0.22);
    border-color: rgba(180, 70, 70, 0.5);
  }
  .cloud-bar .icon {
    width: 18px; height: 18px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 50%;
    color: var(--paper);
    font-size: 11px; font-weight: 700;
    flex-shrink: 0;
  }
  .cloud-bar.disconnected .icon { background: var(--jaune); }
  .cloud-bar.connected .icon { background: var(--vert-2); }
  .cloud-bar.error .icon { background: var(--rouge); }
  .cloud-bar .label {
    flex: 1;
    color: var(--paper-2);
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cloud-bar .label strong { color: var(--paper); font-weight: 500; }
  .cloud-bar .actions { display: flex; gap: 4px; flex-shrink: 0; }
  .cloud-bar button {
    font-size: 12px;
    padding: 4px 8px;
    background: rgba(255, 255, 255, 0.1);
    color: var(--paper);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: none;
  }
  .cloud-bar button:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.3);
  }
  .cloud-bar button.primary {
    background: var(--terre-2);
    border-color: var(--terre-2);
  }
  .cloud-bar button.primary:hover {
    background: var(--terre);
    border-color: var(--terre);
  }
  .cloud-bar .syncing {
    display: inline-block;
    width: 10px; height: 10px;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-top-color: var(--paper);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    margin-right: 4px;
    vertical-align: -1px;
  }

  /* Sur très petits écrans, la cloud-bar passe sous le titre */
  @media (max-width: 600px) {
    .cloud-bar {
      width: 100%;
      max-width: none;
      margin-top: 8px;
    }
    .header-row { flex-direction: column; align-items: stretch; }
    .header-title { width: 100%; }
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Modal config cloud */
  .config-modal { max-width: 480px; }
  .config-modal .modal-body { padding: 20px; }
  .config-modal h3 {
    font-size: 14px;
    margin-bottom: 8px;
    color: var(--ink);
    font-weight: 500;
  }
  .config-modal p {
    font-size: 13px;
    color: var(--ink-2);
    margin-bottom: 14px;
    line-height: 1.5;
  }
  .config-modal .provider-card {
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 14px;
    margin-bottom: 10px;
    background: var(--paper);
  }
  .config-modal .provider-card.unavailable {
    opacity: 0.5;
    background: var(--paper-2);
  }
  .config-modal .provider-card .head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }
  .config-modal .provider-card .name {
    font-size: 15px;
    font-weight: 500;
  }
  .config-modal .provider-card .desc {
    font-size: 12px;
    color: var(--ink-3);
  }
  .config-modal .info {
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-left: 3px solid var(--terre);
    padding: 10px 12px;
    margin-top: 14px;
    font-size: 12px;
    color: var(--ink-2);
    border-radius: 0 3px 3px 0;
  }

  /* Liste sauvegardes Drive */
  .backup-list { list-style: none; }
  .backup-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: 3px;
    margin-bottom: 6px;
    background: var(--paper);
    cursor: pointer;
    gap: 10px;
  }
  .backup-item:hover { background: var(--paper-2); border-color: var(--terre-2); }
  .backup-item .meta { flex: 1; min-width: 0; }
  .backup-item .name {
    font-weight: 500;
    font-size: 14px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .backup-item .date {
    font-size: 12px;
    color: var(--ink-3);
    margin-top: 2px;
  }
  .backup-item .size {
    font-size: 11px;
    color: var(--ink-3);
    font-feature-settings: 'tnum';
  }
  .backup-item .tag {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--terre);
    color: var(--paper);
    padding: 2px 6px;
    border-radius: 2px;
  }

  /* File input hidden */
  input[type="file"] { display: none; }

  /* Onglets de navigation principale */
  .tabs {
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    padding: 0 16px;
    display: flex;
    gap: 4px;
    max-width: 1100px;
    margin: 0 auto;
    overflow-x: auto;
  }
  .tab {
    background: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    padding: 14px 18px 11px;
    font-family: inherit;
    font-size: 14px;
    color: var(--ink-2);
    cursor: pointer;
    border-radius: 0;
    box-shadow: none;
    font-weight: 500;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .tab:hover { background: var(--paper-2); color: var(--ink); }
  .tab.active {
    color: var(--terre);
    border-bottom-color: var(--terre);
  }

  /* Vues principales */
  .view { display: block; }
  .view[hidden] { display: none; }

  /* Sous-onglets sanitaire */
  .subtabs {
    display: flex;
    gap: 4px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 16px;
    overflow-x: auto;
  }
  .subtab {
    background: transparent;
    border: none;
    padding: 10px 14px;
    font-family: inherit;
    font-size: 13px;
    color: var(--ink-3);
    cursor: pointer;
    border-radius: 0;
    box-shadow: none;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }
  .subtab:hover:not([disabled]) { color: var(--ink); }
  .subtab[disabled] { cursor: not-allowed; opacity: 0.5; }
  .subtab.active {
    color: var(--ink);
    border-bottom-color: var(--ink);
    font-weight: 500;
  }
  .subview { display: block; }
  .subview[hidden] { display: none; }

  /* Liste des médicaments */
  .med-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .med-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 14px 16px;
    box-shadow: var(--shadow);
    cursor: pointer;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px 16px;
    align-items: start;
  }
  .med-card:hover { border-color: var(--terre-2); background: var(--paper-2); }
  .med-card .nom {
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
  }
  .med-card .meta {
    font-size: 12px;
    color: var(--ink-3);
    margin-top: 2px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .med-card .meta .sep { color: var(--line); }
  .med-card .delais {
    text-align: right;
    font-size: 12px;
    color: var(--ink-2);
    font-feature-settings: 'tnum';
    white-space: nowrap;
  }
  .med-card .delai {
    display: inline-block;
    padding: 2px 8px;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 10px;
    font-size: 11px;
    color: var(--ink-2);
    margin-left: 4px;
  }
  .med-card .delai.zero {
    color: var(--ink-3);
    font-style: italic;
  }
  .med-card .delai strong {
    color: var(--terre);
    font-weight: 500;
  }
  .med-card .notes {
    grid-column: 1 / -1;
    font-size: 13px;
    color: var(--ink-2);
    margin-top: 6px;
    padding-top: 6px;
    border-top: 1px solid var(--line-2);
    line-height: 1.5;
  }

  /* Liste des ordonnances */
  .ord-month-header {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    margin: 18px 0 6px;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--line-2);
  }
  .ord-month-header:first-child { margin-top: 0; }
  .ord-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ord-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 12px 14px;
    box-shadow: var(--shadow);
    cursor: pointer;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: start;
  }
  .ord-card:hover { border-color: var(--terre-2); background: var(--paper-2); }
  .ord-card .thumb {
    width: 60px;
    height: 60px;
    border-radius: 3px;
    background: var(--paper-2);
    border: 1px solid var(--line);
    object-fit: cover;
    flex-shrink: 0;
  }
  .ord-card .thumb-empty {
    width: 60px;
    height: 60px;
    border-radius: 3px;
    background: var(--paper-2);
    border: 1px dashed var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-3);
    font-size: 20px;
    flex-shrink: 0;
  }
  .ord-card .info {
    min-width: 0;
  }
  .ord-card .info .head {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .ord-card .info .veto {
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
  }
  .ord-card .info .date {
    font-size: 12px;
    color: var(--ink-3);
    font-feature-settings: 'tnum';
    white-space: nowrap;
  }
  .ord-card .info .meds {
    font-size: 12px;
    color: var(--ink-2);
    margin-top: 4px;
    line-height: 1.5;
  }
  .ord-card .info .meds .pill {
    display: inline-block;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 1px 8px;
    margin-right: 4px;
    margin-bottom: 2px;
    font-size: 11px;
  }
  .ord-card .info .num {
    font-size: 11px;
    color: var(--ink-3);
    margin-top: 4px;
    font-feature-settings: 'tnum';
  }

  /* Lignes de prescription dans la modal */
  .prescription-line {
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 10px 12px;
    margin-bottom: 8px;
  }
  .prescription-line .line-head {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: center;
    margin-bottom: 8px;
  }
  .prescription-line .line-head .num {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-3);
  }
  .prescription-line .line-head button {
    background: transparent;
    border: none;
    color: var(--rouge);
    cursor: pointer;
    font-size: 13px;
    padding: 2px 8px;
    box-shadow: none;
  }
  .prescription-line .line-head button:hover { background: rgba(139, 42, 42, 0.1); }
  .prescription-line .row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 8px;
    margin-bottom: 6px;
    align-items: center;
  }
  .prescription-line .row:last-child { margin-bottom: 0; }
  .prescription-line .row label {
    font-size: 12px;
    color: var(--ink-2);
  }
  .prescription-line .row input,
  .prescription-line .row select {
    padding: 6px 8px;
    border: 1px solid var(--line);
    background: var(--paper);
    font-family: inherit;
    font-size: 13px;
    color: var(--ink);
    border-radius: 3px;
    width: 100%;
  }

  /* Photo zoom plein écran */
  #photo-zoom-bg {
    background: rgba(0, 0, 0, 0.85);
  }

  /* Menu déroulant ⋮ */
  .menu-wrap { position: relative; }
  .menu {
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 4px;
    box-shadow: 0 6px 20px rgba(42, 31, 18, 0.15);
    min-width: 240px;
    z-index: 50;
    padding: 6px 0;
  }
  .menu-section {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    padding: 6px 14px 4px;
    font-weight: 500;
  }
  .menu-item {
    display: block;
    width: 100%;
    text-align: left;
    padding: 9px 14px;
    border: none;
    background: transparent;
    font-family: inherit;
    font-size: 14px;
    color: var(--ink);
    cursor: pointer;
    box-shadow: none;
    border-radius: 0;
    white-space: nowrap;
  }
  .menu-item:hover { background: var(--paper-2); }
  .menu-item.danger { color: var(--rouge); }
  .menu-item.danger:hover { background: rgba(139, 42, 42, 0.08); }
  .menu-divider {
    height: 1px;
    background: var(--line-2);
    margin: 4px 0;
  }

  /* Formulaire d'ajout */
  .form-step {
    display: none;
  }
  .form-step.active { display: block; }
  .form-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 10px;
    align-items: center;
    margin-bottom: 12px;
  }
  .form-row label.lbl {
    font-size: 13px;
    color: var(--ink-2);
    font-weight: 500;
  }
  .form-row label.lbl.req::after {
    content: ' *';
    color: var(--rouge);
  }
  .form-row input[type="text"],
  .form-row input[type="date"],
  .form-row input[type="number"],
  .form-row select {
    width: 100%;
    padding: 8px 10px;
    border: 1px solid var(--line);
    background: var(--paper);
    font-family: inherit;
    font-size: 14px;
    color: var(--ink);
    border-radius: 3px;
  }
  .form-row input:focus,
  .form-row select:focus {
    outline: 2px solid var(--terre);
    outline-offset: -1px;
  }
  .form-row input[aria-invalid="true"] {
    border-color: var(--rouge);
  }
  .form-error {
    font-size: 12px;
    color: var(--rouge);
    margin-top: -8px;
    margin-bottom: 12px;
    padding-left: 150px;
  }
  .form-help {
    font-size: 11px;
    color: var(--ink-3);
    margin-top: 2px;
    grid-column: 2;
  }
  .form-radio-group {
    display: flex;
    gap: 14px;
  }
  .form-radio-group label {
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
  }
  .form-actions {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--line);
  }
  .form-step-indicator {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    margin-bottom: 14px;
  }
  .form-step-indicator strong {
    color: var(--terre);
    font-weight: 500;
  }
  .form-section-title {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--terre);
    margin: 0 0 14px;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--terre);
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }
    .form-error, .form-help {
      grid-column: 1;
      padding-left: 0;
    }
  }

  /* Responsive */
  @media (max-width: 720px) {
    .table-wrap { display: none; }
    .cards { display: flex; }
    .toolbar { padding: 10px; }
    .field { grid-template-columns: 110px 1fr; gap: 8px; font-size: 13px; }
    main { padding: 12px; }
  }

  /* Réduction du mouvement */
  @media (prefers-reduced-motion: reduce) {
    * { transition: none !important; }
  }
</style>
</head>
<body>

<header>
  <div class="header-row">
    <div class="header-title">
      <h1>Carnet sanitaire <span style="font-size:12px; opacity:0.6; font-variant:normal; letter-spacing:0; margin-left:6px">v0.18</span></h1>
      <div class="sub" id="header-sub">Sprint 1 — gestion du cheptel</div>
    </div>
    <div class="header-actions">
      <!-- Cloud status bar (toujours visible, déplacée depuis la vue Cheptel) -->
      <div class="cloud-bar disconnected" id="cloud-bar">
        <span class="icon" id="cloud-icon">!</span>
        <div class="label" id="cloud-label">
          <strong>Sauvegarde locale</strong>
        </div>
        <div class="actions">
          <button id="cloud-config">Configurer</button>
        </div>
      </div>
      <!-- Menu ⋮ : réglages + données + zone dangereuse -->
      <div class="menu-wrap">
        <button id="data-menu-btn" class="header-menu-btn" title="Réglages et données" aria-haspopup="true" aria-expanded="false">⋮</button>
        <div class="menu" id="data-menu" hidden>
          <div class="menu-section">Réglages</div>
          <button class="menu-item" id="open-settings">⚙ Réglages de l'exploitation</button>
          <div class="menu-divider"></div>
          <div class="menu-section">Import / Export</div>
          <label class="menu-item" for="import-file">⇪ Importer CSV Synel</label>
          <input type="file" id="import-file" accept=".csv,text/csv">
          <button class="menu-item" id="export-json">⇩ Sauvegarder en fichier</button>
          <label class="menu-item" for="restore-file">↺ Restaurer depuis fichier</label>
          <input type="file" id="restore-file" accept=".json,application/json">
          <div class="menu-divider"></div>
          <div class="menu-section">Zone dangereuse</div>
          <button class="menu-item danger" id="reset">Vider la base locale</button>
        </div>
      </div>
    </div>
  </div>
</header>

<nav class="tabs" role="tablist" aria-label="Navigation principale">
  <button class="tab active" data-view="cheptel" role="tab" aria-selected="true">Cheptel</button>
  <button class="tab" data-view="sanitaire" role="tab" aria-selected="false">Sanitaire</button>
</nav>

<main>
  <!-- ================== VUE CHEPTEL ================== -->
  <section class="view" data-view="cheptel">

  <!-- Toolbar -->
  <div class="toolbar" role="toolbar" aria-label="Actions">
    <input type="search" id="search" placeholder="Rechercher (nom, n° national, n° travail)…" autocomplete="off">
    <div class="filters">
      <button class="toggle" id="filter-presents" aria-pressed="true">Présents</button>
      <button class="toggle" id="filter-femelles" aria-pressed="false">♀ Femelles</button>
      <button class="toggle" id="filter-males" aria-pressed="false">♂ Mâles</button>
    </div>
    <button id="add-animal" class="primary" title="Ajouter un animal manuellement">+ Ajouter</button>
  </div>

  <!-- Stats -->
  <div class="stats" id="stats" hidden>
    <div class="stat"><div class="v" id="s-total">0</div><div class="l">Total cheptel</div></div>
    <div class="stat"><div class="v" id="s-presents">0</div><div class="l">Présents</div></div>
    <div class="stat"><div class="v" id="s-femelles">0</div><div class="l">Femelles</div></div>
    <div class="stat"><div class="v" id="s-males">0</div><div class="l">Mâles</div></div>
    <div class="stat"><div class="v" id="s-veaux">0</div><div class="l">Veaux &lt; 8 mois</div></div>
  </div>

  <!-- Empty state -->
  <div class="empty" id="empty">
    <h2>Aucun animal en base</h2>
    <p>Importe un export CSV depuis Synel (format identification permanente) pour commencer. Tes données restent sur cet appareil — rien n'est envoyé ailleurs.</p>
    <div class="actions">
      <label class="btn primary" for="import-file" style="background:var(--terre);color:var(--paper);border-color:var(--terre)">⇪ Importer un CSV Synel</label>
      <button id="load-demo" class="ghost">Charger des données de démo</button>
    </div>
  </div>

  <!-- Table desktop -->
  <div class="table-wrap" id="table-wrap" hidden>
    <table>
      <thead>
        <tr>
          <th data-sort="numTravail">N° trav</th>
          <th data-sort="nom">Nom</th>
          <th data-sort="sexe">Sexe</th>
          <th data-sort="libelleRace">Race</th>
          <th data-sort="dateNaissance">Né le</th>
          <th data-sort="age">Âge</th>
          <th data-sort="mereIPGNom">Mère</th>
          <th data-sort="numNational">N° national</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>

  <!-- Mobile cards -->
  <div class="cards" id="cards"></div>

  </section><!-- /vue cheptel -->

  <!-- ================== VUE SANITAIRE ================== -->
  <section class="view" data-view="sanitaire" hidden>

    <!-- Sous-navigation sanitaire -->
    <nav class="subtabs" role="tablist">
      <button class="subtab active" data-subview="medicaments" role="tab" aria-selected="true">Bibliothèque médicaments</button>
      <button class="subtab" data-subview="ordonnances" role="tab" aria-selected="false">Ordonnances</button>
      <button class="subtab" data-subview="soins" role="tab" aria-selected="false" disabled title="Disponible en v0.18">Soins</button>
    </nav>

    <!-- Sous-vue : Bibliothèque médicaments -->
    <div class="subview" data-subview="medicaments">

      <div class="toolbar" role="toolbar" aria-label="Actions médicaments">
        <input type="search" id="med-search" placeholder="Rechercher un médicament…" autocomplete="off">
        <button id="add-medicament" class="primary" style="background:var(--terre);color:var(--paper);border-color:var(--terre)">+ Nouveau médicament</button>
      </div>

      <!-- Empty state -->
      <div class="empty" id="med-empty" hidden>
        <h2>Bibliothèque vide</h2>
        <p>Ajoute les médicaments que tu utilises au fil de leurs prescriptions. La bibliothèque s'enrichit progressivement et chaque médicament saisi sera ensuite réutilisable pour les soins.</p>
        <div class="actions">
          <button id="add-medicament-empty" class="btn primary" style="background:var(--terre);color:var(--paper);border-color:var(--terre)">+ Ajouter un médicament</button>
        </div>
      </div>

      <!-- Liste -->
      <div class="med-list" id="med-list"></div>
    </div>

    <!-- Sous-vue : Ordonnances -->
    <div class="subview" data-subview="ordonnances" hidden>

      <div class="toolbar" role="toolbar" aria-label="Actions ordonnances">
        <input type="search" id="ord-search" placeholder="Rechercher (vétérinaire, n°, médicament)…" autocomplete="off">
        <button id="add-ordonnance" class="primary" style="background:var(--terre);color:var(--paper);border-color:var(--terre)">+ Nouvelle ordonnance</button>
      </div>

      <!-- Empty state -->
      <div class="empty" id="ord-empty" hidden>
        <h2>Aucune ordonnance enregistrée</h2>
        <p>Saisis tes ordonnances vétérinaires au fur et à mesure. Tu peux joindre une photo de l'original et préciser les médicaments prescrits avec leur posologie.</p>
        <div class="actions">
          <button id="add-ordonnance-empty" class="btn primary" style="background:var(--terre);color:var(--paper);border-color:var(--terre)">+ Première ordonnance</button>
        </div>
      </div>

      <!-- Liste -->
      <div class="ord-list" id="ord-list"></div>
    </div>

  </section><!-- /vue sanitaire -->
</main>

<!-- Modal détail -->
<div class="modal-bg" id="modal-bg" role="dialog" aria-modal="true">
  <div class="modal" id="modal-content"></div>
</div>

<!-- Modal config cloud -->
<div class="modal-bg" id="config-modal-bg" role="dialog" aria-modal="true">
  <div class="modal config-modal">
    <div class="modal-head">
      <h2>Sauvegarde cloud</h2>
      <button class="close" id="config-close" aria-label="Fermer">×</button>
    </div>
    <div class="modal-body" id="config-body"></div>
  </div>
</div>

<!-- Modal liste sauvegardes -->
<div class="modal-bg" id="backups-modal-bg" role="dialog" aria-modal="true">
  <div class="modal config-modal">
    <div class="modal-head">
      <h2>Restaurer depuis Drive</h2>
      <button class="close" id="backups-close" aria-label="Fermer">×</button>
    </div>
    <div class="modal-body" id="backups-body"></div>
  </div>
</div>

<!-- Modal d'ajout d'animal (formulaire 2 étapes) -->
<div class="modal-bg" id="add-modal-bg" role="dialog" aria-modal="true">
  <div class="modal config-modal" style="max-width:560px">
    <div class="modal-head">
      <h2>Ajouter un animal</h2>
      <button class="close" id="add-close" aria-label="Fermer">×</button>
    </div>
    <div class="modal-body">
      <div class="form-step-indicator" id="form-indicator">
        <strong>Étape 1/2</strong> · Identification
      </div>

      <!-- Étape 1 : Identification -->
      <div class="form-step active" id="form-step-1">
        <div class="form-section-title">Identification de l'animal</div>

        <div class="form-row">
          <label class="lbl req" for="add-num-national">N° national</label>
          <div>
            <input type="text" id="add-num-national" placeholder="ex: 3100495777" inputmode="numeric" maxlength="12" autocomplete="off">
            <div class="form-help">10 chiffres après FR (ou 8 chiffres en saisie courte)</div>
          </div>
        </div>
        <div class="form-error" id="err-num-national" hidden></div>

        <div class="form-row">
          <label class="lbl" for="add-num-travail">N° travail</label>
          <div>
            <input type="text" id="add-num-travail" placeholder="auto si vide" maxlength="6" autocomplete="off">
            <div class="form-help">Boucle ferme courte (4-6 chiffres). Auto-déduit du n° national si vide.</div>
          </div>
        </div>

        <div class="form-row">
          <label class="lbl" for="add-nom">Nom</label>
          <input type="text" id="add-nom" placeholder="optionnel" maxlength="40" autocomplete="off">
        </div>

        <div class="form-row">
          <label class="lbl req">Sexe</label>
          <div class="form-radio-group">
            <label><input type="radio" name="add-sexe" value="F"> ♀ Femelle</label>
            <label><input type="radio" name="add-sexe" value="M"> ♂ Mâle</label>
          </div>
        </div>
        <div class="form-error" id="err-sexe" hidden></div>

        <div class="form-row">
          <label class="lbl req" for="add-naissance">Né le</label>
          <input type="date" id="add-naissance">
        </div>
        <div class="form-error" id="err-naissance" hidden></div>

        <div class="form-row">
          <label class="lbl req" for="add-race">Race</label>
          <select id="add-race">
            <option value="">— Choisir —</option>
            <!-- Rempli dynamiquement avec les races officielles -->
          </select>
        </div>
        <div class="form-error" id="err-race" hidden></div>

        <div class="form-row">
          <label class="lbl" for="add-cause-entree">Entrée</label>
          <select id="add-cause-entree">
            <option value="N">Naissance (cheptel)</option>
            <option value="A">Achat</option>
            <option value="I">Introduction</option>
          </select>
        </div>

        <div class="form-row" id="row-date-entree" hidden>
          <label class="lbl" for="add-date-entree">Date d'entrée</label>
          <input type="date" id="add-date-entree">
        </div>

        <div class="form-actions">
          <button type="button" class="ghost" id="add-cancel">Annuler</button>
          <button type="button" class="primary" id="add-next" style="background:var(--terre);color:var(--paper);border-color:var(--terre)">Suivant →</button>
        </div>
      </div>

      <!-- Étape 2 : Filiation (optionnelle) -->
      <div class="form-step" id="form-step-2">
        <div class="form-section-title">Filiation <span style="color:var(--ink-3);font-weight:400;font-size:12px;text-transform:none;letter-spacing:0">— optionnelle</span></div>

        <p style="font-size:13px;color:var(--ink-2);margin-bottom:18px">
          Si tu connais les parents, indique-les ci-dessous. Sinon, laisse vide et passe à l'enregistrement.
        </p>

        <div class="form-section-title" style="font-size:11px">Mère</div>
        <div class="form-row">
          <label class="lbl" for="add-mere-select">Mère du cheptel</label>
          <select id="add-mere-select">
            <option value="">— Aucune ou inconnue —</option>
          </select>
        </div>
        <div class="form-help" style="margin-top:-8px;margin-bottom:14px;padding-left:150px">
          Liste des femelles présentes. Pour saisir une mère hors cheptel, utiliser les champs ci-dessous.
        </div>

        <div class="form-row">
          <label class="lbl" for="add-mere-num">N° mère (manuel)</label>
          <input type="text" id="add-mere-num" placeholder="optionnel" autocomplete="off">
        </div>
        <div class="form-row">
          <label class="lbl" for="add-mere-nom">Nom mère</label>
          <input type="text" id="add-mere-nom" placeholder="optionnel" autocomplete="off">
        </div>
        <div class="form-row">
          <label class="lbl" for="add-mere-race">Race mère</label>
          <select id="add-mere-race">
            <option value="">— Inconnue —</option>
          </select>
        </div>

        <div class="form-section-title" style="font-size:11px;margin-top:24px">Père</div>
        <div class="form-row">
          <label class="lbl" for="add-pere-select">Père du cheptel</label>
          <select id="add-pere-select">
            <option value="">— Inconnu ou hors cheptel —</option>
          </select>
        </div>
        <div class="form-help" style="margin-top:-8px;margin-bottom:14px;padding-left:150px">
          Mâles présents de plus de 8 mois. Sinon, saisir manuellement ci-dessous.
        </div>

        <div class="form-row">
          <label class="lbl" for="add-pere-num">N° père (manuel)</label>
          <input type="text" id="add-pere-num" placeholder="optionnel" autocomplete="off">
        </div>
        <div class="form-row">
          <label class="lbl" for="add-pere-nom">Nom père</label>
          <input type="text" id="add-pere-nom" placeholder="optionnel" autocomplete="off">
        </div>
        <div class="form-row">
          <label class="lbl" for="add-pere-race">Race père</label>
          <select id="add-pere-race">
            <option value="">— Inconnue —</option>
          </select>
        </div>

        <div class="form-actions">
          <button type="button" class="ghost" id="add-back">← Retour</button>
          <button type="button" class="primary" id="add-save" style="background:var(--terre);color:var(--paper);border-color:var(--terre)">Enregistrer</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal Réglages -->
<div class="modal-bg" id="settings-modal-bg" role="dialog" aria-modal="true">
  <div class="modal config-modal" style="max-width:480px">
    <div class="modal-head">
      <h2>Réglages de l'exploitation</h2>
      <button class="close" id="settings-close" aria-label="Fermer">×</button>
    </div>
    <div class="modal-body">
      <div class="form-section-title">Mode de production</div>

      <div style="background:var(--paper-2);border:1px solid var(--line);border-radius:4px;padding:14px;margin-bottom:14px">
        <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer">
          <input type="checkbox" id="settings-bio" style="margin-top:3px;width:18px;height:18px;cursor:pointer">
          <div>
            <div style="font-size:15px;font-weight:500;color:var(--ink)">Exploitation en agriculture biologique (AB)</div>
            <div style="font-size:12px;color:var(--ink-2);margin-top:4px;line-height:1.5">
              Quand cette option est activée, les délais d'attente conventionnels affichés sur les ordonnances sont automatiquement <strong>doublés</strong>, avec un minimum de 48 heures, conformément au règlement CE 889/2008.
            </div>
            <div style="font-size:11px;color:var(--ink-3);margin-top:6px;font-style:italic">
              Exemple : un médicament avec 14 jours de délai conventionnel passe à 28 jours en AB.
            </div>
          </div>
        </label>
      </div>

      <div class="info" id="bio-warning" hidden>
        <strong>⚠ Important :</strong> activer ou désactiver le mode AB modifie l'affichage des délais. Cela ne change pas les délais des soins déjà enregistrés (qui restent ancrés sur le mode actif au moment de leur saisie).
      </div>

      <!-- Champ date de conversion : visible seulement si bio coché -->
      <div id="conversion-date-block" hidden style="background:var(--paper-2);border:1px solid var(--line);border-radius:4px;padding:14px;margin-top:14px">
        <div style="font-size:14px;font-weight:500;color:var(--ink);margin-bottom:8px">Date de conversion de l'exploitation</div>
        <div style="font-size:12px;color:var(--ink-2);line-height:1.5;margin-bottom:10px">
          Date à laquelle ton exploitation est passée en bio. Sert à calculer le statut bio de chaque animal :
          <ul style="margin:6px 0 0 18px;padding:0;font-size:11px">
            <li><strong>Bio</strong> : né en bio, ou conversion terminée (12 mois après achat, ou 75% de la vie en bio)</li>
            <li><strong>Conversion</strong> : encore en période de conversion</li>
            <li><strong>Conventionnel</strong> : aucune partie de la vie passée en bio</li>
          </ul>
        </div>
        <input type="date" id="settings-date-conversion"
               style="padding:8px 10px;border:1px solid var(--line);background:var(--paper);font-family:inherit;font-size:14px;color:var(--ink);border-radius:3px;width:100%;max-width:200px">
      </div>

      <div class="form-actions" style="border-top:none;padding-top:8px">
        <div></div>
        <button type="button" class="primary" id="settings-save" style="background:var(--terre);color:var(--paper);border-color:var(--terre)">Enregistrer</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal d'édition d'un médicament -->
<div class="modal-bg" id="med-modal-bg" role="dialog" aria-modal="true">
  <div class="modal config-modal" style="max-width:520px">
    <div class="modal-head">
      <h2 id="med-modal-title">Nouveau médicament</h2>
      <button class="close" id="med-close" aria-label="Fermer">×</button>
    </div>
    <div class="modal-body">
      <div class="form-section-title">Identification</div>

      <div class="form-row">
        <label class="lbl req" for="med-nom">Nom commercial</label>
        <div>
          <input type="text" id="med-nom" placeholder="ex: Bovipast RSP, Penistrep…" maxlength="80" autocomplete="off">
          <div class="form-help">Nom tel qu'il figure sur l'ordonnance</div>
        </div>
      </div>
      <div class="form-error" id="err-med-nom" hidden></div>

      <div class="form-row">
        <label class="lbl" for="med-amm">N° AMM</label>
        <div>
          <input type="text" id="med-amm" placeholder="optionnel" maxlength="40" autocomplete="off">
          <div class="form-help">Numéro d'autorisation de mise sur le marché</div>
        </div>
      </div>

      <div class="form-row">
        <label class="lbl" for="med-forme">Forme</label>
        <select id="med-forme">
          <option value="">— Choisir —</option>
          <option value="injectable">Injectable (sous-cutané, intramusculaire…)</option>
          <option value="oral">Oral (bolus, pâte, liquide…)</option>
          <option value="intra-mammaire">Intra-mammaire</option>
          <option value="intra-uterin">Intra-utérin</option>
          <option value="externe">Externe (pour-on, spray, pommade…)</option>
          <option value="autre">Autre</option>
        </select>
      </div>

      <div class="form-section-title" style="margin-top:24px">Délais d'attente</div>
      <p style="font-size:12px;color:var(--ink-3);margin:-10px 0 14px">Indique les délais en jours tels que figurés sur l'ordonnance ou la notice. Laisse à 0 si aucun délai.</p>

      <div class="form-row">
        <label class="lbl req" for="med-delai-viande">Délai viande</label>
        <div style="display:flex;align-items:center;gap:8px">
          <input type="number" id="med-delai-viande" min="0" max="365" step="1" value="0" style="width:90px">
          <span style="color:var(--ink-3);font-size:13px">jours</span>
        </div>
      </div>

      <div class="form-row">
        <label class="lbl" for="med-delai-lait">Délai lait</label>
        <div style="display:flex;align-items:center;gap:8px">
          <input type="number" id="med-delai-lait" min="0" max="100" step="1" value="0" style="width:90px">
          <span style="color:var(--ink-3);font-size:13px">jours (laisser 0 si non concerné)</span>
        </div>
      </div>

      <div class="form-section-title" style="margin-top:24px">Notes</div>

      <div class="form-row" style="grid-template-columns:1fr">
        <textarea id="med-notes" rows="3" placeholder="Posologie habituelle, indications, observations…"
                  style="width:100%;padding:8px 10px;border:1px solid var(--line);background:var(--paper);font-family:inherit;font-size:14px;color:var(--ink);border-radius:3px;resize:vertical"></textarea>
      </div>

      <div class="form-actions">
        <button type="button" class="ghost danger" id="med-delete" hidden>🗑 Supprimer</button>
        <div style="display:flex;gap:10px;margin-left:auto">
          <button type="button" class="ghost" id="med-cancel">Annuler</button>
          <button type="button" class="primary" id="med-save" style="background:var(--terre);color:var(--paper);border-color:var(--terre)">Enregistrer</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal d'édition d'une ordonnance -->
<div class="modal-bg" id="ord-modal-bg" role="dialog" aria-modal="true">
  <div class="modal config-modal" style="max-width:600px">
    <div class="modal-head">
      <h2 id="ord-modal-title">Nouvelle ordonnance</h2>
      <button class="close" id="ord-close" aria-label="Fermer">×</button>
    </div>
    <div class="modal-body">
      <div class="form-section-title">Informations</div>

      <div class="form-row">
        <label class="lbl req" for="ord-date">Date de prescription</label>
        <input type="date" id="ord-date">
      </div>
      <div class="form-error" id="err-ord-date" hidden></div>

      <div class="form-row">
        <label class="lbl req" for="ord-veto">Vétérinaire</label>
        <input type="text" id="ord-veto" placeholder="Dr Martin · Clinique de Saint-Gaudens" maxlength="120" autocomplete="off">
      </div>
      <div class="form-error" id="err-ord-veto" hidden></div>

      <div class="form-row">
        <label class="lbl" for="ord-numero">N° d'ordonnance</label>
        <input type="text" id="ord-numero" placeholder="optionnel — ex: 2026-042" maxlength="40" autocomplete="off">
      </div>

      <div class="form-section-title" style="margin-top:24px">Photo de l'ordonnance</div>

      <div id="ord-photo-zone">
        <!-- État : pas de photo -->
        <div id="ord-photo-empty">
          <label class="btn primary" for="ord-photo-input" style="background:var(--terre);color:var(--paper);border-color:var(--terre);display:inline-block">📷 Prendre une photo</label>
          <input type="file" id="ord-photo-input" accept="image/*" capture="environment">
          <label class="btn ghost" for="ord-photo-file-input" style="display:inline-block;margin-left:8px">📁 Choisir un fichier</label>
          <input type="file" id="ord-photo-file-input" accept="image/*">
          <div class="form-help" style="margin-top:8px;padding-left:0">La photo est compressée et stockée localement. Aucune limite de taille pratique.</div>
        </div>
        <!-- État : photo prise -->
        <div id="ord-photo-preview" hidden>
          <img id="ord-photo-img" src="" alt="Photo de l'ordonnance" style="max-width:100%;max-height:300px;border:1px solid var(--line);border-radius:3px;cursor:pointer">
          <div style="display:flex;gap:8px;margin-top:8px;flex-wrap:wrap;align-items:center">
            <span id="ord-photo-info" style="font-size:12px;color:var(--ink-3)"></span>
            <div style="margin-left:auto;display:flex;gap:6px">
              <label class="btn ghost" for="ord-photo-replace" style="font-size:12px;padding:4px 10px">Remplacer</label>
              <input type="file" id="ord-photo-replace" accept="image/*">
              <button type="button" class="ghost danger" id="ord-photo-remove" style="font-size:12px;padding:4px 10px">Supprimer</button>
            </div>
          </div>
        </div>
      </div>

      <div class="form-section-title" style="margin-top:24px">Médicaments prescrits</div>
      <p style="font-size:12px;color:var(--ink-3);margin:-10px 0 14px">Liste des médicaments figurant sur l'ordonnance avec leur posologie.</p>

      <div id="ord-prescriptions"></div>

      <button type="button" class="ghost" id="ord-add-prescription" style="font-size:13px;margin-top:8px">+ Ajouter un médicament</button>

      <div class="form-section-title" style="margin-top:24px">Notes</div>
      <div class="form-row" style="grid-template-columns:1fr">
        <textarea id="ord-notes" rows="3" placeholder="Indications, observations…"
                  style="width:100%;padding:8px 10px;border:1px solid var(--line);background:var(--paper);font-family:inherit;font-size:14px;color:var(--ink);border-radius:3px;resize:vertical"></textarea>
      </div>

      <div class="form-actions">
        <button type="button" class="ghost danger" id="ord-delete" hidden>🗑 Supprimer</button>
        <div style="display:flex;gap:10px;margin-left:auto">
          <button type="button" class="ghost" id="ord-cancel">Annuler</button>
          <button type="button" class="primary" id="ord-save" style="background:var(--terre);color:var(--paper);border-color:var(--terre)">Enregistrer</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal de visualisation photo plein écran -->
<div class="modal-bg" id="photo-zoom-bg" role="dialog" aria-modal="true">
  <div style="max-width:95vw;max-height:95vh;display:flex;flex-direction:column;align-items:center;gap:10px">
    <img id="photo-zoom-img" src="" alt="Photo plein écran" style="max-width:100%;max-height:85vh;border:1px solid var(--line);border-radius:3px">
    <button class="ghost" id="photo-zoom-close" style="background:rgba(0,0,0,0.5);color:white;border-color:rgba(255,255,255,0.3)">Fermer</button>
  </div>
</div>

<div class="toast" id="toast" role="status" aria-live="polite"></div>

<script>
'use strict';

/* ============================================================
   CONSTANTES — codes officiels Idele/BDNI
   ============================================================ */

// Table officielle Idele — méthodologie 2024, mise à jour janvier 2025
// type : 'lait' | 'viande' | 'mixte' | 'croise'
// principale : true si race non menacée et > 2000 carcasses vaches/an sur 5 dernières années
const RACES = {
  // Type Lait
  '18': { nom: 'Ayrshire', type: 'lait' },
  '42': { nom: 'Dairy Shorthorn', type: 'lait' },
  '74': { nom: 'Guernesey', type: 'lait' },
  '15': { nom: 'Jersiaise', type: 'lait', principale: true },
  '19': { nom: 'Pie Rouge des Plaines', type: 'lait', principale: true },
  '66': { nom: 'Prim\'Holstein', type: 'lait', principale: true },
  '44': { nom: 'Autres races traites étrangères', type: 'lait' },

  // Type Mixte
  '12': { nom: 'Abondance', type: 'mixte', principale: true },
  '26': { nom: 'Bordelaise', type: 'mixte' },
  '29': { nom: 'Bretonne pie noire', type: 'mixte', principale: true },
  '21': { nom: 'Brune', type: 'mixte', principale: true },
  '20': { nom: 'Buffle', type: 'mixte' },
  '92': { nom: 'Canadienne', type: 'mixte' },
  '69': { nom: 'Froment du Léon', type: 'mixte' },
  '78': { nom: 'Gelbvieh', type: 'mixte' },
  '86': { nom: 'Highland Cattle', type: 'mixte', principale: true },
  '46': { nom: 'Montbéliarde', type: 'mixte', principale: true },
  '54': { nom: 'N\'Dama', type: 'mixte' },
  '56': { nom: 'Normande', type: 'mixte', principale: true },
  '63': { nom: 'Rouge flamande', type: 'mixte' },
  '35': { nom: 'Simmental française', type: 'mixte', principale: true },
  '31': { nom: 'Tarentaise', type: 'mixte', principale: true },
  '53': { nom: 'Villard de Lans', type: 'mixte', principale: true },
  '57': { nom: 'Vosgienne', type: 'mixte' },

  // Type Viande
  '17': { nom: 'Angus', type: 'viande', principale: true },
  '43': { nom: 'Armoricaine', type: 'viande' },
  '14': { nom: 'Aubrac', type: 'viande', principale: true },
  '30': { nom: 'Aurochs reconstitué', type: 'viande' },
  '24': { nom: 'Bazadaise', type: 'viande' },
  '61': { nom: 'Béarnaise', type: 'viande' },
  '10': { nom: 'Bison', type: 'viande' },
  '25': { nom: 'Blanc Bleu', type: 'viande', principale: true },
  '22': { nom: 'Bleue de Bazougers', type: 'viande' },
  '52': { nom: 'Bleue du Nord', type: 'viande' },
  '79': { nom: 'Blonde d\'Aquitaine', type: 'viande', principale: true },
  '81': { nom: 'Brahman (Zébu)', type: 'viande' },
  '97': { nom: 'Casta (Aure et St Girons)', type: 'viande' },
  '38': { nom: 'Charolaise', type: 'viande', principale: true },
  '32': { nom: 'Chianina', type: 'viande' },
  '36': { nom: 'Corse', type: 'viande' },
  '55': { nom: 'Créole', type: 'viande' },
  '51': { nom: 'De Combat (Espagnole brava)', type: 'viande' },
  '65': { nom: 'Ferrandaise', type: 'viande' },
  '73': { nom: 'Galloway', type: 'viande' },
  '72': { nom: 'Gasconne', type: 'viande', principale: true },
  '85': { nom: 'Hereford', type: 'viande', principale: true },
  '82': { nom: 'Herens', type: 'viande' },
  '95': { nom: 'Inra 95', type: 'viande', principale: true },
  '34': { nom: 'Limousine', type: 'viande', principale: true },
  '33': { nom: 'Lourdaise', type: 'viande' },
  '58': { nom: 'Maraichine', type: 'viande' },
  '49': { nom: 'Marchigiana', type: 'viande' },
  '64': { nom: 'Marine Landaise', type: 'viande' },
  '77': { nom: 'Mirandaise (Gasconne aréolée)', type: 'viande' },
  '80': { nom: 'Moka', type: 'viande' },
  '76': { nom: 'Nantaise', type: 'viande' },
  '71': { nom: 'Parthenaise', type: 'viande', principale: true },
  '75': { nom: 'Piémontaise', type: 'viande' },
  '11': { nom: 'Pirenaica', type: 'viande' },
  '37': { nom: 'Raço di Biou', type: 'viande' },
  '41': { nom: 'Rouge des Prés', type: 'viande', principale: true },
  '23': { nom: 'Salers', type: 'viande', principale: true },
  '88': { nom: 'Saosnoise', type: 'viande' },
  '45': { nom: 'South Devon', type: 'viande' },
  '13': { nom: 'Wagyu', type: 'viande' },
  '90': { nom: 'Zébu', type: 'viande' },
  '48': { nom: 'Autres races allaitantes étrangères', type: 'viande' },

  // Croisés
  '39': { nom: 'Croisée', type: 'croise' }
};

const CAUSES_ENTREE = {
  'N': 'Naissance', 'A': 'Achat', 'I': 'Introduction', 'P': 'Prêt',
  'R': 'Retour', 'X': 'Autre'
};

const CAUSES_SORTIE = {
  'B': 'Boucherie', 'M': 'Mort', 'V': 'Vente vif', 'E': 'Export',
  'P': 'Prêt', 'S': 'Auto-consommation', 'X': 'Autre'
};

const STORAGE_KEY = 'carnet-sanitaire-v1';

/* ============================================================
   ÉTAT
   ============================================================ */

const state = {
  animaux: [],
  medicaments: [],     // bibliothèque perso de médicaments vétérinaires
  ordonnances: [],     // ordonnances vétérinaires (avec photos)
  soins: [],           // soins administrés (à activer en v0.19)
  settings: {          // réglages globaux de l'exploitation
    bio: false,        // mode AB : double les délais d'attente (min 48h)
    dateConversion: null  // date à laquelle l'exploitation est passée en bio (ISO YYYY-MM-DD)
  },
  // Versions locales par section, incrémentées à chaque modif. Comparées au manifest
  // distant lors de la synchronisation pour ne télécharger/uploader que ce qui a changé.
  versions: {
    cheptel: 0,
    medicaments: 0,
    ordonnances: 0,
    soins: 0,
    settings: 0
  },
  // Liste des photos absentes localement (présentes dans les ordonnances mais le dataUrl
  // est null). Permet d'afficher "📥 télécharger" et de gérer le mode photos-on-demand.
  photosManquantes: [],
  filtres: { presents: true, femelles: false, males: false, recherche: '' },
  tri: { col: 'numTravail', asc: false },
  vue: 'cheptel'       // 'cheptel' ou 'sanitaire'
};

// Helper : marque une section comme modifiée (incrémente sa version)
// À appeler partout où on modifie state.X (ex: après ajout d'un animal, d'un médicament, etc.)
function bumpVersion(section) {
  if (!state.versions[section]) state.versions[section] = 0;
  state.versions[section]++;
}

/* ============================================================
   PERSISTENCE LOCALE (localStorage pour V1, Dexie en V2)
   ============================================================ */

function persist() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({
      version: 5,
      savedAt: new Date().toISOString(),
      animaux: state.animaux,
      medicaments: state.medicaments,
      ordonnances: state.ordonnances,
      soins: state.soins,
      settings: state.settings,
      versions: state.versions,
      photosManquantes: state.photosManquantes
    }));
    // Déclenche une sauvegarde cloud différée si configuré
    if (typeof scheduleAutoSave === 'function') scheduleAutoSave();
  } catch (e) {
    toast('Erreur de sauvegarde locale : ' + e.message, 'error');
  }
}

function load() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return;
    const data = JSON.parse(raw);
    if (data.animaux && Array.isArray(data.animaux)) {
      state.animaux = data.animaux;
    }
    if (data.medicaments && Array.isArray(data.medicaments)) {
      state.medicaments = data.medicaments;
    }
    if (data.settings && typeof data.settings === 'object') {
      state.settings = { ...state.settings, ...data.settings };
    }
    if (data.ordonnances && Array.isArray(data.ordonnances)) {
      state.ordonnances = data.ordonnances;
    }
    if (data.soins && Array.isArray(data.soins)) {
      state.soins = data.soins;
    }
    // Rétrocompatibilité v5+ : versions et photosManquantes
    if (data.versions && typeof data.versions === 'object') {
      state.versions = { ...state.versions, ...data.versions };
    }
    if (data.photosManquantes && Array.isArray(data.photosManquantes)) {
      state.photosManquantes = data.photosManquantes;
    }
  } catch (e) {
    console.warn('Restauration impossible :', e);
  }
}

/* ============================================================
   PARSER CSV SYNEL
   Format : ; séparateur, CRLF, ASCII, codes mnémoniques
   ============================================================ */

function parseCSVSynel(text) {
  // Nettoie BOM éventuel
  if (text.charCodeAt(0) === 0xFEFF) text = text.slice(1);

  const lines = text.split(/\r?\n/).filter(l => l.length > 0);
  if (lines.length < 2) throw new Error('Fichier vide ou sans données');

  const headers = lines[0].split(';').map(h => h.trim());
  const REQUIRED = ['NUNATI', 'NUTRAV', 'DANAIS', 'TYRASU', 'SEXBOV'];
  const missing = REQUIRED.filter(c => !headers.includes(c));
  if (missing.length) {
    throw new Error('Colonnes Synel manquantes : ' + missing.join(', '));
  }

  const idx = {};
  headers.forEach((h, i) => { idx[h] = i; });

  const animaux = [];
  for (let i = 1; i < lines.length; i++) {
    const cells = lines[i].split(';');
    const get = (k) => (idx[k] !== undefined ? (cells[idx[k]] || '').trim() : '');

    const numNational = get('NUNATI');
    if (!numNational) continue;

    const sexe = get('SEXBOV');
    const codeRace = get('TYRASU');
    const causeSortie = get('CAUSSO');
    const dateSortie = parseDateFR(get('DATESO'));

    const animal = {
      id: get('COPAIP') + numNational,
      pays: get('COPAIP'),
      numNational: numNational,
      numTravail: get('NUTRAV'),
      nom: get('NOBOVI') || null,
      dateNaissance: parseDateFR(get('DANAIS')),
      codeRace: codeRace,
      libelleRace: (RACES[codeRace] && RACES[codeRace].nom) || ('Race ' + codeRace),
      typeRace: (RACES[codeRace] && RACES[codeRace].type) || null,
      sexe: sexe,
      causeEntree: get('CAUSEN'),
      libelleCauseEntree: CAUSES_ENTREE[get('CAUSEN')] || get('CAUSEN'),
      dateEntree: parseDateFR(get('DATEEN')),
      causeSortie: causeSortie || null,
      libelleCauseSortie: causeSortie ? (CAUSES_SORTIE[causeSortie] || causeSortie) : null,
      dateSortie: dateSortie,
      mereIPG: extractParent(get, 'COPAMI', 'NUMEIP', 'NOMEIP', 'TRAMIP'),
      mereCPB: extractParent(get, 'COPAME', 'NUMERE', 'NOMERE', 'TRAMER'),
      pere: extractParent(get, 'COPAPE', 'NUPERE', 'NOPERE', 'TRAPER'),
      importedAt: new Date().toISOString(),
      source: 'synel-csv-v1'
    };
    animaux.push(animal);
  }

  return animaux;
}

function extractParent(get, kPays, kNum, kNom, kRace) {
  const num = get(kNum);
  if (!num) return null;
  return {
    pays: get(kPays),
    numNational: num,
    nom: get(kNom) || null,
    codeRace: get(kRace),
    libelleRace: (RACES[get(kRace)] && RACES[get(kRace)].nom) || ('Race ' + get(kRace))
  };
}

function parseDateFR(s) {
  if (!s) return null;
  const m = s.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
  if (!m) return null;
  return m[3] + '-' + m[2] + '-' + m[1]; // ISO
}

function formatDateFR(iso) {
  if (!iso) return '—';
  const m = iso.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  return m ? m[3] + '/' + m[2] + '/' + m[1] : iso;
}

function calcAge(dateNaissance) {
  if (!dateNaissance) return null;
  const naiss = new Date(dateNaissance);
  const now = new Date();
  let years = now.getFullYear() - naiss.getFullYear();
  let months = now.getMonth() - naiss.getMonth();
  if (now.getDate() < naiss.getDate()) months--;
  if (months < 0) { years--; months += 12; }
  return { years, months, totalMonths: years * 12 + months };
}

function formatAge(dateNaissance) {
  const a = calcAge(dateNaissance);
  if (!a) return '—';
  if (a.totalMonths < 1) return '< 1 mois';
  if (a.years === 0) return a.months + ' mois';
  if (a.months === 0) return a.years + ' an' + (a.years > 1 ? 's' : '');
  return a.years + ' an' + (a.years > 1 ? 's' : '') + ' ' + a.months + ' m';
}

/* ============================================================
   RENDU
   ============================================================ */

// Pastille de statut bio à afficher devant le nom de l'animal
// Vide si mode AB désactivé (pour ne pas polluer la liste)
function renderBioPastille(a) {
  if (!state.settings.bio) return '';
  const status = computeBioStatus(a);
  const colors = { 'bio': '#4a8a1f', 'conversion': '#d49a14', 'conventionnel': '#a0a0a0' };
  const labels = { 'bio': 'Bio', 'conversion': 'Conversion', 'conventionnel': 'Conventionnel' };
  const titre = `${labels[status.status]} — ${status.detail}`;
  return `<span class="bio-dot" style="background:${colors[status.status]}" title="${escapeHtml(titre)}" data-status="${status.status}"></span>`;
}

// Section "Statut bio" pour la fiche détail
function renderBioSection(a) {
  const status = computeBioStatus(a);
  const colors = { 'bio': '#4a8a1f', 'conversion': '#d49a14', 'conventionnel': '#a0a0a0' };
  const labels = { 'bio': '🟢 Bio certifié', 'conversion': '🟡 En conversion', 'conventionnel': '⚪ Conventionnel' };

  // Sélecteur du mode de calcul (auto / forcé bio / forcé conventionnel)
  const isAuto = a.bioManuel === undefined || a.bioManuel === null;
  const isForcedBio = a.bioManuel === true;
  const isForcedConv = a.bioManuel === false;

  const controlsHtml = `
    <div class="field">
      <div class="l">Mode de calcul</div>
      <div class="v" style="font-size:13px">
        <div class="bio-mode-group">
          <label class="bio-mode-option${isAuto ? ' active' : ''}">
            <input type="radio" name="bio-mode-${a.id}" value="auto" ${isAuto ? 'checked' : ''} data-animal-id="${a.id}">
            <span>Automatique</span>
          </label>
          <label class="bio-mode-option${isForcedBio ? ' active' : ''}">
            <input type="radio" name="bio-mode-${a.id}" value="bio" ${isForcedBio ? 'checked' : ''} data-animal-id="${a.id}">
            <span>🟢 Bio (acheté bio)</span>
          </label>
          <label class="bio-mode-option${isForcedConv ? ' active' : ''}">
            <input type="radio" name="bio-mode-${a.id}" value="conventionnel" ${isForcedConv ? 'checked' : ''} data-animal-id="${a.id}">
            <span>⚪ Conventionnel</span>
          </label>
        </div>
        <div style="font-size:11px;color:var(--ink-3);margin-top:4px;line-height:1.4">
          Mode "Bio" à utiliser pour un animal <strong>acheté déjà bio</strong> dans une autre exploitation certifiée — il évite les 12 mois de conversion individuelle.
        </div>
      </div>
    </div>
  `;

  const fieldsHtml = `
    <div class="field">
      <div class="l">Statut</div>
      <div class="v"><strong style="color:${colors[status.status]}">${labels[status.status]}</strong>${status.manuel ? ' <span style="font-size:11px;color:var(--ink-3)">(manuel)</span>' : ''}</div>
    </div>
    <div class="field">
      <div class="l">Détail</div>
      <div class="v" style="font-size:13px">${status.detail}</div>
    </div>
    ${controlsHtml}
  `;
  return '<div class="section-title">Statut bio (AB)</div>' + fieldsHtml;
}

function applyFilters(animaux) {
  const q = state.filtres.recherche.trim().toLowerCase();
  return animaux.filter(a => {
    if (state.filtres.presents && a.dateSortie) return false;
    if (state.filtres.femelles && a.sexe !== 'F') return false;
    if (state.filtres.males && a.sexe !== 'M') return false;
    if (q) {
      const hay = [a.nom, a.numNational, a.numTravail, a.libelleRace,
                   a.mereIPG?.nom, a.mereIPG?.numNational]
                  .filter(Boolean).join(' ').toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });
}

function applySort(animaux) {
  const { col, asc } = state.tri;
  const dir = asc ? 1 : -1;
  return [...animaux].sort((a, b) => {
    let va, vb;
    if (col === 'mereIPGNom') {
      va = a.mereIPG?.nom || ''; vb = b.mereIPG?.nom || '';
    } else if (col === 'age') {
      va = a.dateNaissance || ''; vb = b.dateNaissance || '';
      // Pour l'âge, plus vieux = date plus ancienne, on inverse
      return (va < vb ? 1 : va > vb ? -1 : 0) * dir;
    } else {
      va = a[col] ?? ''; vb = b[col] ?? '';
    }
    if (typeof va === 'string') va = va.toLowerCase();
    if (typeof vb === 'string') vb = vb.toLowerCase();
    return (va < vb ? -1 : va > vb ? 1 : 0) * dir;
  });
}

function render() {
  const empty = document.getElementById('empty');
  const tw = document.getElementById('table-wrap');
  const cards = document.getElementById('cards');
  const stats = document.getElementById('stats');

  if (state.animaux.length === 0) {
    empty.style.display = 'block';
    tw.hidden = true;
    cards.style.display = 'none';
    stats.hidden = true;
    return;
  }

  empty.style.display = 'none';
  stats.hidden = false;
  renderStats();

  const filtered = applySort(applyFilters(state.animaux));

  // Desktop table
  const tbody = document.getElementById('tbody');
  tbody.innerHTML = '';
  for (const a of filtered) {
    const tr = document.createElement('tr');
    if (a.dateSortie) tr.classList.add('sortie');
    tr.dataset.id = a.id;
    const bioPastille = renderBioPastille(a);
    tr.innerHTML = `
      <td class="num-trav">${a.numTravail || '—'}</td>
      <td class="nom">${bioPastille}${a.nom || '<span style="color:var(--ink-3)">[' + (a.numTravail || '?') + ']</span>'}</td>
      <td><span class="badge ${a.sexe.toLowerCase()}">${a.sexe === 'F' ? '♀' : '♂'}</span></td>
      <td><span class="badge race">${a.libelleRace}</span></td>
      <td>${formatDateFR(a.dateNaissance)}</td>
      <td>${formatAge(a.dateNaissance)}</td>
      <td>${a.mereIPG?.nom || (a.mereIPG?.numNational ? '#' + a.mereIPG.numNational.slice(-4) : '—')}</td>
      <td style="color:var(--ink-3)">${a.pays} ${a.numNational}</td>
    `;
    tr.addEventListener('click', () => showDetail(a.id));
    tbody.appendChild(tr);
  }
  tw.hidden = false;
  // Sort indicators
  document.querySelectorAll('thead th').forEach(th => {
    th.classList.remove('sort-asc', 'sort-desc');
    if (th.dataset.sort === state.tri.col) {
      th.classList.add(state.tri.asc ? 'sort-asc' : 'sort-desc');
    }
  });

  // Mobile cards
  cards.innerHTML = '';
  for (const a of filtered) {
    const div = document.createElement('div');
    div.className = 'card' + (a.dateSortie ? ' sortie' : '');
    div.dataset.id = a.id;
    const bioPastille = renderBioPastille(a);
    div.innerHTML = `
      <div class="card-head">
        <div class="nom">${bioPastille}${a.nom || '[' + (a.numTravail || '?') + ']'}</div>
        <div class="ntrav">n° ${a.numTravail || '—'}</div>
      </div>
      <div class="card-meta">
        <span class="badge ${a.sexe.toLowerCase()}">${a.sexe === 'F' ? '♀' : '♂'}</span>
        <span>${a.libelleRace}</span>
        <span class="sep">·</span>
        <span>${formatAge(a.dateNaissance)}</span>
        ${a.mereIPG?.nom ? '<span class="sep">·</span><span>mère ' + a.mereIPG.nom + '</span>' : ''}
      </div>
      <div class="card-num">${a.pays} ${a.numNational}${a.dateSortie ? ' · sorti le ' + formatDateFR(a.dateSortie) : ''}</div>
    `;
    div.addEventListener('click', () => showDetail(a.id));
    cards.appendChild(div);
  }

  // Header sub : compteur + indicateur AB si actif
  const bioLabel = state.settings.bio ? ' · 🌱 Mode AB' : '';
  document.getElementById('header-sub').textContent =
    `${filtered.length} animaux affichés sur ${state.animaux.length}${bioLabel}`;
}

function renderStats() {
  const tot = state.animaux.length;
  const pres = state.animaux.filter(a => !a.dateSortie);
  const f = pres.filter(a => a.sexe === 'F').length;
  const m = pres.filter(a => a.sexe === 'M').length;
  const veaux = pres.filter(a => {
    const age = calcAge(a.dateNaissance);
    return age && age.totalMonths < 8;
  }).length;
  document.getElementById('s-total').textContent = tot;
  document.getElementById('s-presents').textContent = pres.length;
  document.getElementById('s-femelles').textContent = f;
  document.getElementById('s-males').textContent = m;
  document.getElementById('s-veaux').textContent = veaux;
}

/* ============================================================
   DÉTAIL
   ============================================================ */

function showDetail(id) {
  const a = state.animaux.find(x => x.id === id);
  if (!a) return;
  const m = document.getElementById('modal-content');

  const fields = (rows) => rows.map(r => `
    <div class="field">
      <div class="l">${r[0]}</div>
      <div class="v">${r[1] ?? '—'}</div>
    </div>`).join('');

  let parentSection = '';
  if (a.mereIPG) {
    parentSection += '<div class="section-title">Mère (IPG)</div>' + fields([
      ['N° national', a.mereIPG.pays + ' ' + a.mereIPG.numNational],
      ['Nom', a.mereIPG.nom],
      ['Race', a.mereIPG.libelleRace]
    ]);
  }
  if (a.mereCPB && a.mereCPB.numNational !== a.mereIPG?.numNational) {
    parentSection += '<div class="section-title">Mère (CPB — certifiée)</div>' + fields([
      ['N° national', a.mereCPB.pays + ' ' + a.mereCPB.numNational],
      ['Nom', a.mereCPB.nom],
      ['Race', a.mereCPB.libelleRace]
    ]);
  }
  if (a.pere) {
    parentSection += '<div class="section-title">Père</div>' + fields([
      ['N° national', a.pere.pays + ' ' + (a.pere.numNational || '—')],
      ['Nom', a.pere.nom],
      ['Race', a.pere.libelleRace]
    ]);
  }

  // Titre avec bouton crayon pour éditer le nom
  const displayName = a.nom || '[' + a.numTravail + ']';
  const headerHtml = `
    <div class="modal-head" id="detail-head">
      <h2 style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
        <span id="detail-name">${displayName}</span>
        <button class="ghost" id="edit-name-btn" title="Modifier le nom" style="padding:3px 8px;font-size:14px;box-shadow:none">✎</button>
      </h2>
      <button class="close" aria-label="Fermer">×</button>
    </div>`;

  m.innerHTML = `
    ${headerHtml}
    <div class="modal-body">
      <div class="section-title">Identification</div>
      ${fields([
        ['N° national', a.pays + ' ' + a.numNational],
        ['N° travail', a.numTravail],
        ['Sexe', a.sexe === 'F' ? 'Femelle' : 'Mâle'],
        ['Race', a.libelleRace + ' (code ' + a.codeRace + ')' + (a.typeRace ? ' · type ' + a.typeRace : '')]
      ])}
      <div class="section-title">Vie</div>
      ${fields([
        ['Né le', formatDateFR(a.dateNaissance) + ' · ' + formatAge(a.dateNaissance)],
        ['Entrée', formatDateFR(a.dateEntree) + ' · ' + a.libelleCauseEntree],
        ['Sortie', a.dateSortie ? (formatDateFR(a.dateSortie) + ' · ' + a.libelleCauseSortie) : 'Présent']
      ])}
      ${state.settings.bio ? renderBioSection(a) : ''}
      ${parentSection}
      <div style="margin-top:24px;padding-top:14px;border-top:1px solid var(--line);display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap">
        <button class="ghost danger" id="delete-animal-btn">🗑 Supprimer l'animal</button>
        <button class="ghost" id="detail-close-btn">Fermer</button>
      </div>
    </div>
  `;

  // Liaisons
  document.getElementById('modal-bg').classList.add('show');
  m.querySelector('.close').addEventListener('click', closeModal);
  document.getElementById('detail-close-btn').addEventListener('click', closeModal);
  document.getElementById('edit-name-btn').addEventListener('click', () => startEditName(a));
  document.getElementById('delete-animal-btn').addEventListener('click', () => deleteAnimal(a));

  // Listener pour le changement de mode bio (si le mode AB est actif)
  if (state.settings.bio) {
    m.querySelectorAll(`input[name="bio-mode-${a.id}"]`).forEach(radio => {
      radio.addEventListener('change', (e) => onBioModeChange(a.id, e.target.value));
    });
  }
}

// Changement de mode bio depuis la fiche détail
function onBioModeChange(animalId, mode) {
  const animal = state.animaux.find(x => x.id === animalId);
  if (!animal) return;
  if (mode === 'auto') animal.bioManuel = null;
  else if (mode === 'bio') animal.bioManuel = true;
  else if (mode === 'conventionnel') animal.bioManuel = false;
  bumpVersion('cheptel');
  persist();
  render();           // met à jour les pastilles dans la liste
  showDetail(animalId); // re-render la fiche pour mettre à jour le statut affiché
  const labels = { 'auto': 'calcul automatique', 'bio': 'forcé bio', 'conventionnel': 'forcé conventionnel' };
  toast(`Statut ${labels[mode]}`, 'success');
}

// Édition inline du nom
function startEditName(animal) {
  const head = document.getElementById('detail-head');
  if (!head) return;
  const currentName = animal.nom || '';
  head.querySelector('h2').innerHTML = `
    <input type="text" id="edit-name-input" value="${currentName.replace(/"/g, '&quot;')}"
           placeholder="${animal.numTravail ? '[' + animal.numTravail + ']' : 'Nom'}"
           maxlength="40"
           style="font-family:inherit;font-size:18px;padding:4px 8px;border:1px solid var(--line);background:var(--paper);color:var(--ink);border-radius:3px;width:200px">
    <button class="primary" id="save-name-btn" style="background:var(--terre);color:var(--paper);border-color:var(--terre);padding:4px 10px;font-size:13px">OK</button>
    <button class="ghost" id="cancel-name-btn" style="padding:4px 10px;font-size:13px">Annuler</button>
  `;
  const input = document.getElementById('edit-name-input');
  input.focus();
  input.select();

  const save = () => {
    const newName = input.value.trim() || null;
    animal.nom = newName;
    bumpVersion('cheptel');
    persist();
    render();
    showDetail(animal.id); // re-affiche la fiche avec le nouveau nom
    toast('Nom mis à jour', 'success');
  };

  const cancel = () => showDetail(animal.id);

  document.getElementById('save-name-btn').addEventListener('click', save);
  document.getElementById('cancel-name-btn').addEventListener('click', cancel);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') save();
    if (e.key === 'Escape') {
      e.stopPropagation(); // empêche la fermeture de la modale
      cancel();
    }
  });
}

// Suppression d'un animal avec garde-fous
function deleteAnimal(animal) {
  const displayName = animal.nom || '[' + animal.numTravail + ']';

  // Vérifie si cet animal est référencé comme parent d'autres animaux
  const enfants = state.animaux.filter(a =>
    a.id !== animal.id && (
      a.mereIPG?.numNational === animal.numNational ||
      a.mereCPB?.numNational === animal.numNational ||
      a.pere?.numNational === animal.numNational
    )
  );

  let confirmMsg = `Supprimer définitivement ${displayName} de la base ?\n\nCette action est irréversible.`;
  if (enfants.length > 0) {
    const noms = enfants.slice(0, 3).map(e => e.nom || '[' + e.numTravail + ']').join(', ');
    const plus = enfants.length > 3 ? ` et ${enfants.length - 3} autre${enfants.length - 3 > 1 ? 's' : ''}` : '';
    confirmMsg += `\n\n⚠ Attention : ${enfants.length} animal${enfants.length > 1 ? 'ux' : ''} (${noms}${plus}) ${enfants.length > 1 ? 'ont' : 'a'} cet animal comme parent. Leurs filiations seront conservées telles quelles (n° et nom préservés), mais le lien direct vers la fiche sera perdu.`;
  }

  if (!confirm(confirmMsg)) return;

  state.animaux = state.animaux.filter(a => a.id !== animal.id);
  bumpVersion('cheptel');
  persist();
  render();
  closeModal();
  toast(`${displayName} supprimé du cheptel`);
}

function closeModal() {
  document.getElementById('modal-bg').classList.remove('show');
}

/* ============================================================
   IMPORT / EXPORT / RESTAURATION
   ============================================================ */

async function handleImport(file) {
  try {
    const text = await file.text();
    const animaux = parseCSVSynel(text);
    if (animaux.length === 0) {
      toast('Aucun animal trouvé dans le fichier', 'error');
      return;
    }
    // Fusion par n° national : on remplace les existants, on ajoute les nouveaux
    const map = new Map(state.animaux.map(a => [a.id, a]));
    let added = 0, updated = 0;
    for (const a of animaux) {
      if (map.has(a.id)) updated++; else added++;
      map.set(a.id, a);
    }
    state.animaux = Array.from(map.values());
    bumpVersion('cheptel');
    persist();
    render();
    toast(`Import OK — ${added} nouveau${added > 1 ? 'x' : ''}, ${updated} mis à jour`, 'success');
  } catch (e) {
    toast('Erreur d\'import : ' + e.message, 'error');
  }
}

function exportJSON() {
  const data = {
    version: 4,
    exportedAt: new Date().toISOString(),
    animaux: state.animaux,
    medicaments: state.medicaments,
    ordonnances: state.ordonnances,
    soins: state.soins,
    settings: state.settings
  };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  const date = new Date().toISOString().slice(0, 10);
  a.href = url;
  a.download = `carnet-sanitaire-${date}.json`;
  document.body.appendChild(a);
  a.click();
  setTimeout(() => { URL.revokeObjectURL(url); a.remove(); }, 100);
  toast('Sauvegarde téléchargée', 'success');
}

async function handleRestore(file) {
  try {
    const text = await file.text();
    const data = JSON.parse(text);
    if (!data.animaux || !Array.isArray(data.animaux)) {
      throw new Error('Format de sauvegarde invalide');
    }
    const nbMeds = (data.medicaments && Array.isArray(data.medicaments)) ? data.medicaments.length : 0;
    const nbOrd = (data.ordonnances && Array.isArray(data.ordonnances)) ? data.ordonnances.length : 0;
    let parts = [`${data.animaux.length} animaux`];
    if (nbMeds > 0) parts.push(`${nbMeds} médicament${nbMeds > 1 ? 's' : ''}`);
    if (nbOrd > 0) parts.push(`${nbOrd} ordonnance${nbOrd > 1 ? 's' : ''}`);
    const msg = `Restaurer ${parts.join(', ')} ? Les données actuelles seront remplacées.`;
    if (!confirm(msg)) return;
    state.animaux = data.animaux;
    state.medicaments = (data.medicaments && Array.isArray(data.medicaments)) ? data.medicaments : [];
    state.ordonnances = (data.ordonnances && Array.isArray(data.ordonnances)) ? data.ordonnances : [];
    state.soins = (data.soins && Array.isArray(data.soins)) ? data.soins : [];
    if (data.settings && typeof data.settings === 'object') {
      state.settings = { ...state.settings, ...data.settings };
    }
    persist();
    render();
    toast(`${data.animaux.length} animaux restaurés`, 'success');
  } catch (e) {
    toast('Erreur de restauration : ' + e.message, 'error');
  }
}

function reset() {
  if (!confirm('Vider toutes les données locales ? Cette action est irréversible (sauf si vous avez une sauvegarde).')) return;
  state.animaux = [];
  state.medicaments = [];
  state.ordonnances = [];
  state.soins = [];
  state.settings = { bio: false, dateConversion: null };
  localStorage.removeItem(STORAGE_KEY);
  render();
  toast('Base vidée');
}

