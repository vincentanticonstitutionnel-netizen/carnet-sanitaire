// Menu déroulant ⋮ (Données et sauvegarde)
const dataMenu = document.getElementById('data-menu');
const dataMenuBtn = document.getElementById('data-menu-btn');
function toggleDataMenu(open) {
  const isOpen = open !== undefined ? open : dataMenu.hidden;
  dataMenu.hidden = !isOpen;
  dataMenuBtn.setAttribute('aria-expanded', isOpen);
}
dataMenuBtn.addEventListener('click', (e) => {
  e.stopPropagation();
  toggleDataMenu();
});
// Fermer le menu en cliquant ailleurs
document.addEventListener('click', (e) => {
  if (!dataMenu.hidden && !dataMenu.contains(e.target) && e.target !== dataMenuBtn) {
    toggleDataMenu(false);
  }
});
// Fermer le menu après clic sur un item
dataMenu.querySelectorAll('.menu-item').forEach(item => {
  item.addEventListener('click', () => toggleDataMenu(false));
});

// Modal d'ajout d'animal
